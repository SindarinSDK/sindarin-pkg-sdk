# ==============================================================================
# test_rwlock.sn - Tests for SDK RwLock Type
# ==============================================================================

import "../../src/sync/rwlock"
import "../../src/time/time"

fn test_basic_read_write(): void =>
    print("test_basic_read_write: ")
    var rw: RwLock = RwLock.new()

    rw.readLock()
    rw.readUnlock()

    rw.writeLock()
    rw.writeUnlock()

    rw.dispose()
    print("PASS\n")

fn test_write_then_read(): void =>
    print("test_write_then_read: ")
    var rw: RwLock = RwLock.new()

    rw.writeLock()
    rw.writeUnlock()

    rw.readLock()
    rw.readUnlock()

    rw.dispose()
    print("PASS\n")

var sharedRw: RwLock
var sharedData: int = 0
sync var doneCount: int = 0

fn writerOnly(): void =>
    var i: int = 0
    while i < 100 =>
        sharedRw.writeLock()
        sharedData = sharedData + 1
        sharedRw.writeUnlock()
        i = i + 1
    doneCount++

fn test_two_writers(): void =>
    print("test_two_writers: ")
    sharedRw = RwLock.new()
    doneCount = 0
    sharedData = 0

    &writerOnly()
    &writerOnly()

    while doneCount < 2 =>
        Time.sleep(1)

    assert(sharedData == 200, $"Expected 200, got {sharedData}")
    sharedRw.dispose()
    print("PASS\n")

fn readerOnly(): void =>
    var i: int = 0
    while i < 100 =>
        sharedRw.readLock()
        var x: int = sharedData
        sharedRw.readUnlock()
        i = i + 1
    doneCount++

fn test_readers_and_writers(): void =>
    print("test_readers_and_writers: ")
    sharedRw = RwLock.new()
    doneCount = 0
    sharedData = 0

    &readerOnly()
    &readerOnly()
    &writerOnly()
    &writerOnly()

    while doneCount < 4 =>
        Time.sleep(1)

    assert(sharedData == 200, $"Expected 200, got {sharedData}")
    sharedRw.dispose()
    print("PASS\n")

fn main(): void =>
    test_basic_read_write()
    test_write_then_read()
    test_two_writers()
    test_readers_and_writers()
