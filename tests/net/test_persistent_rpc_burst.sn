# ==============================================================================
# test_persistent_rpc_burst.sn - Stress test for QUIC stream lifecycle churn
# ==============================================================================
# Opens one fresh bidi stream per RPC iteration for 300 iterations on a single
# connection. This deliberately exceeds the default initial_max_streams_bidi
# (100) so that the peer's MAX_STREAMS credit replenishment is exercised many
# times in a row.
#
# Known flake: this test surfaces a stream-lifecycle race in the SDK's
# QuicConnection state machine — probably in the interaction between
# stream_close_cb, find_or_create_stream, and the client-side openStream
# retry path — that fires under CPU contention. The assertion
#
# "Client stream N should be open (stream budget exhausted?)"
#
# fires at an iteration around 30-80 (well below the 100-stream budget), so
# the "budget exhausted" hint in the message is misleading. See
# docs/issues/quic_persistent_rpc_burst_flake.md for the full analysis.
#
# This test lives in its own file so it can be excluded from CI via
# run_tests --exclude test_persistent_rpc_burst until the race is fixed,
# without losing any other coverage in test_quic.sn.
# ==============================================================================

import "sindarin-pkg-sdk/src/net/quic"
import "sindarin-pkg-sdk/src/time/time"

# Server-side echo RPC loop: accept one stream per iteration, read a single
# line request, write a single line response, close the stream.
fn serverRpcEchoLoop(conn: QuicConnection, count: int): int =>
  for var i: int = 0; i < count; i++ =>
    var ss: QuicStream = conn.acceptStream()
    if ss.isClosed() =>
      return i
    var req: str = ss.readLine()
    assert(req == $"req-{i}", $"Server expected 'req-{i}' but got '{req}'")
    ss.writeLine($"resp-{i}")
    ss.close()

  return count

fn test_persistent_rpc_burst(): void =>
  print("test_persistent_rpc_burst: ")
  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var serverCfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, serverCfg)
  var port: int = server.port()

  var clientCfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", clientCfg)
  var serverConn: QuicConnection = server.accept()

  var total: int = 300
  var serverHandle: int = & serverRpcEchoLoop(serverConn, total)
  serverHandle ~

  for var i: int = 0; i < total; i++ =>
    var cs: QuicStream = client.openStream()
    assert(!cs.isClosed(), $"Client stream {i} should be open (stream budget exhausted?)")
    cs.writeLine($"req-{i}")
    var resp: str = cs.readLine()
    assert(resp == $"resp-{i}", $"Expected 'resp-{i}' but got '{resp}'")
    cs.close()

  client.close()
  serverConn.close()
  server.close()

  print("PASS\n")

fn main(): void =>
  print("=== QUIC Persistent RPC Burst Test ===\n\n")
  test_persistent_rpc_burst()
  print("\nTest passed!\n")
