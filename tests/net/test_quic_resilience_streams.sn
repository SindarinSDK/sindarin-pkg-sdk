# ==============================================================================
# test_quic_resilience.sn - Failure-mode tests for QUIC
# ==============================================================================
# These tests describe the REQUIRED resilience behavior of the QUIC stack:
#
# (a) Connect must fail in bounded time when the peer is not ready,
# so one-shot callers don't wedge on startup/readiness races.
# (b) Idle timeout must mark the connection closed in bounded time.
# (c) Pending readLine() / acceptStream() / write() on a connection must
# unblock and surface a clean signal when the peer closes — never
# hang on a lost condition-variable wakeup.
# (d) Post-close operations must not crash, and repeated close must be
# idempotent.
#
# Every test has a wall-clock deadline. Background operations run in spawned
# threads and communicate with main via `sync var` flags; main polls those
# flags until a deadline, then asserts. A regression therefore fails loudly
# within seconds instead of hanging the runner until its 30s wall timeout.
#
# Some of these tests describe behavior that is NOT currently correct on main.
# Those tests are the regression gate for the upcoming fixes. The comment on
# each test says what it catches.
# ==============================================================================

import "sindarin-pkg-sdk/src/net/quic"
import "sindarin-pkg-sdk/src/net/tcp"
import "sindarin-pkg-sdk/src/time/time"

# ==============================================================================
# Shared state for background threads
# ==============================================================================
# Reused across tests via resetBg() — tests run sequentially so there is no
# cross-test contention.

sync var bgDone: bool = false
sync var bgElapsedMs: long = 0l
sync var bgResultInt: int = 0
sync var bgResultStr: str = ""

# Second set of flags for tests that need two concurrent background threads
sync var bg2Done: bool = false
sync var bg2ResultStr: str = ""

fn resetBg(): void =>
  bgDone = false
  bgElapsedMs = 0l
  bgResultInt = 0
  bgResultStr = ""
  bg2Done = false
  bg2ResultStr = ""

# Poll `bgDone` at 50ms intervals until it flips or `timeoutMs` elapses.
# Returns true if the flag flipped, false on deadline.
fn waitForBg(timeoutMs: long): bool =>
  var deadline: long = Time.now().millis() + timeoutMs
  while !bgDone =>
    if Time.now().millis() >= deadline =>
      return false
    Time.sleep(50)
  return true

# ==============================================================================
# Test 1: connect() to a port with no listener must return in bounded time.
# ==============================================================================
# Regression gate for: one-shot callers that start before a sibling service is
# ready must not block for 30 seconds on the default idle timeout. We force a
# short idle timeout via config and assert the call returns within 5 seconds.
#
# Passes on main IF ngtcp2's idle timer is honoured as a handshake bound.
# Fails if the handshake wait is unbounded, or if connect() deadlocks on the
# closed-path condition broadcast.

fn connectNoListenerBg(port: int): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(2000)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgDone = true
  return 0

fn test_connect_without_listener_is_bounded(): void =>
  print("test_connect_without_listener_is_bounded: ")
  resetBg()

  # High port unlikely to have anything bound. A false negative (something
  # IS listening on 59999) still respects the deadline invariant.
  var h: int = & connectNoListenerBg(59999)

  assert(waitForBg(3000l),
    "connect() to dead port did not return within 3s (idleTimeout=2000ms)")
  assert(bgElapsedMs <= 3000l,
    $"connect() took {bgElapsedMs}ms, expected <= 3000ms")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 2: startup race — client must be able to retry until the server appears.
# ==============================================================================
# Regression gate for the one-shot startup race: a client process that starts
# before a sibling server is bound must be able to retry connect() in a loop
# and succeed once the server comes up. Since the SDK does not yet expose
# connectWithRetry, this documents the caller-side pattern using the existing
# API: short idleTimeout per attempt, isClosed() check after connect, backoff,
# retry. A regression that makes connect() crash on failure, or isClosed()
# unsafe on a failed handle, or leaks state across failed attempts, will
# break this test loudly.

fn delayedServerBind(targetPort: int, certPath: str, keyPath: str, delayMs: int): int =>
  Time.sleep(delayMs)
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith($":{targetPort}", certPath, keyPath, cfg)
  var sc: QuicConnection = server.accept()
  var ss: QuicStream = sc.acceptStream()
  var msg: str = ss.readLine()
  assert(msg == "hello-after-retry",
    $"delayed server expected 'hello-after-retry', got '{msg}'")
  ss.writeLine("world-after-retry")
  ss.close()
  sc.close()
  server.close()
  return 0

fn test_connect_retries_while_server_not_ready(): void =>
  print("test_connect_retries_while_server_not_ready: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  # Claim a free UDP port, then release it. The background thread will
  # rebind on that port 500ms later. UDP has no TIME_WAIT so the port is
  # immediately available for rebinding.
  var placeholder: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var port: int = placeholder.port()
  placeholder.close()

  # Schedule the real listener to come up 500ms from now. Main thread
  # will start retrying connect() immediately.
  var h: int = & delayedServerBind(port, cert_path, key_path, 500)

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(800)
  var connected: bool = false
  var attempts: int = 0
  var startMs: long = Time.now().millis()

  while !connected && attempts < 10 =>
    attempts++
    var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
    if c.isClosed() =>
      # Attempt failed — the handle is already closed. Back off and retry.
      Time.sleep(200)
    else =>
      # Handshake succeeded — verify the connection is usable with a round trip.
      var cs: QuicStream = c.openStream()
      cs.writeLine("hello-after-retry")
      var resp: str = cs.readLine()
      assert(resp == "world-after-retry",
        $"expected 'world-after-retry', got '{resp}'")
      cs.close()
      c.close()
      connected = true

  var elapsedMs: long = Time.now().millis() - startMs
  assert(connected,
    $"client failed to connect after {attempts} attempts in {elapsedMs}ms")
  assert(elapsedMs < 10000l,
    $"retry loop took {elapsedMs}ms, expected < 10000ms")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 3: idle timeout must mark the connection closed in bounded time.
# ==============================================================================
# Regression gate for: a live connection whose peer goes silent must flip
# isClosed() when the configured idle timeout expires. If ngtcp2's expiry
# callback doesn't propagate into ci->closed, long-lived consumers will sit
# on a dead connection indefinitely.

fn test_idle_timeout_marks_closed(): void =>
  print("test_idle_timeout_marks_closed: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var serverCfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, serverCfg)
  var port: int = server.port()

  var clientCfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", clientCfg)
  var serverConn: QuicConnection = server.accept()

  # Neither side sends anything. Both idle timers should fire at ~1s.
  # Allow 3s slack for scheduler + ngtcp2 grace.
  var deadline: long = Time.now().millis() + 3000l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false,
        "client.isClosed() never became true after idle timeout (1000ms)")
    Time.sleep(50)

  assert(client.isClosed(), "client must be closed after idle timeout")

  # Both sides were idle; server should also flip eventually. Give it the
  # same 3s envelope relative to start.
  var deadline2: long = Time.now().millis() + 3000l
  while !serverConn.isClosed() =>
    if Time.now().millis() >= deadline2 =>
      assert(false,
        "serverConn.isClosed() never became true after idle timeout (1000ms)")
    Time.sleep(50)

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 4: abrupt peer death — isClosed() must flip via idle timer.
# ==============================================================================
# Regression gate for long-lived callers: when the server process vanishes
# without sending CONNECTION_CLOSE (SIGKILL, crash, network partition), the
# client must detect the silence via its idle timer and flip isClosed() in
# bounded time. This is simulated with quicTestDropSocket() which severs the
# server-side UDP path without any graceful frame.

fn test_isclosed_flips_after_server_drop(): void =>
  print("test_isclosed_flips_after_server_drop: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Round trip to confirm both sides are live before we drop.
  var cs: QuicStream = client.openStream()
  cs.writeLine("alive")
  var ss: QuicStream = serverConn.acceptStream()
  var alive: str = ss.readLine()
  assert(alive == "alive", $"server should see 'alive', got '{alive}'")

  # Abruptly drop the server-side UDP path. No CONNECTION_CLOSE is sent.
  # Client must notice via its idle timer (1500ms) and flip isClosed.
  serverConn.quicTestDropSocket()

  var deadline: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false,
        "client.isClosed() did not flip within 2.5s of abrupt server drop")
    Time.sleep(50)

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 5: a pending readLine() must unblock when the peer closes.
# ==============================================================================
# Regression gate for: lost-wakeup bug in the close path. If the I/O thread
# flips ci->closed without broadcasting the stream's read_cond, a reader that
# parked before the close will block forever and never observe the state flip.
# This is the bug described in section 1d of the analysis.

fn pendingReadLineBg(stream: QuicStream): int =>
  var start: Time = Time.now()
  var s: str = stream.readLine()
  bgElapsedMs = Time.now().diff(start)
  bgResultStr = s
  bgDone = true
  return 0

# Helper used by the stream-budget test: call openStream in a background
# thread so the parent can bound the call with a wall deadline.
fn pendingOpenStreamBg(conn: QuicConnection): int =>
  var s: QuicStream = conn.openStream()
  bgResultInt = 1
  if s.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_pending_read_wakes_on_peer_close(): void =>
  print("test_pending_read_wakes_on_peer_close: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  # Use idleTimeout=0 to prove the wakeup comes from close, not from the
  # idle timer firing underneath us.
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Client opens a stream and sends one line so the server can observe it.
  # Server drains that line but does not respond. The client then parks on
  # its next readLine() — there is nothing to read until peer close.
  var clientStream: QuicStream = client.openStream()
  clientStream.writeLine("hello")

  var serverStream: QuicStream = serverConn.acceptStream()
  var greeting: str = serverStream.readLine()
  assert(greeting == "hello", $"server should see 'hello', got '{greeting}'")

  # Park the client readLine in a background thread.
  var h: int = & pendingReadLineBg(clientStream)

  # Give the reader enough time to reach its COND_WAIT.
  Time.sleep(300)

  # Server gracefully closes. The client's parked readLine MUST unblock.
  serverStream.close()
  serverConn.close()
  server.close()

  assert(waitForBg(3000l),
    "client readLine() did not wake within 3s of peer close — lost wakeup bug")
  assert(bgElapsedMs <= 3000l,
    $"client readLine() took {bgElapsedMs}ms to wake, expected <= 3000ms")
  h ~

  client.close()
  print("PASS\n")

# ==============================================================================
# Test 6: a pending readLine() must unblock on abrupt server death.
# ==============================================================================
# Regression gate for the lost-wakeup bug class on the abrupt-death path: if
# the I/O thread's idle-timer exit doesn't broadcast the stream's read_cond
# via quic_io_thread_cleanup, a parked reader will never observe the closed
# flag flipping and will deadlock.

fn test_pending_read_wakes_when_server_drops(): void =>
  print("test_pending_read_wakes_when_server_drops: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Establish the stream with a greeting so both sides have a real stream
  # object. The server then stays silent — client's next readLine parks.
  var cs: QuicStream = client.openStream()
  cs.writeLine("greeting")
  var ss: QuicStream = serverConn.acceptStream()
  var greeting: str = ss.readLine()
  assert(greeting == "greeting", $"server should see 'greeting', got '{greeting}'")

  # Park the client readLine in a background thread.
  var h: int = & pendingReadLineBg(cs)

  # Give the background thread enough time to reach its COND_WAIT.
  Time.sleep(200)

  # Abruptly drop the server-side socket. No graceful frame is sent.
  # The client must detect silence via its idle timer and wake the reader.
  serverConn.quicTestDropSocket()

  assert(waitForBg(2500l),
    "client readLine did not wake within 2.5s of abrupt server drop")
  h ~

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 7: a pending acceptStream() must unblock when the connection closes.
# ==============================================================================
# Regression gate for: same lost-wakeup class, but on the accept_stream_cond
# path. If close() doesn't broadcast this cond, a server parked on
# acceptStream() will deadlock when the client goes away.

fn pendingAcceptStreamBg(conn: QuicConnection): int =>
  var start: Time = Time.now()
  var s: QuicStream = conn.acceptStream()
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if s.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_pending_accept_wakes_on_peer_close(): void =>
  print("test_pending_accept_wakes_on_peer_close: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Server parks on acceptStream() — client never opens one.
  var h: int = & pendingAcceptStreamBg(serverConn)

  Time.sleep(300)

  # Client closes. Server's parked acceptStream() must wake.
  client.close()

  assert(waitForBg(3000l),
    "serverConn.acceptStream() did not wake within 3s of client close")
  assert(bgElapsedMs <= 3000l,
    $"acceptStream() took {bgElapsedMs}ms to wake, expected <= 3000ms")
  h ~

  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 8: a pending acceptStream() must unblock on abrupt client death.
# ==============================================================================
# Symmetric to test 6 but on the accept_stream_cond path. If the server's I/O
# thread exits via idle timer without broadcasting accept_stream_cond through
# quic_io_thread_cleanup, a server parked on acceptStream() will deadlock.

fn test_pending_accept_wakes_when_client_drops(): void =>
  print("test_pending_accept_wakes_when_client_drops: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Server parks on acceptStream — the client never opens one, it just dies.
  var h: int = & pendingAcceptStreamBg(serverConn)

  Time.sleep(200)

  # Abruptly drop the client-side socket. No graceful frame is sent.
  # Server must detect silence via its idle timer and wake the accept.
  client.quicTestDropSocket()

  assert(waitForBg(2500l),
    "server acceptStream did not wake within 2.5s of abrupt client drop")
  h ~

  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 9: reads after peer close must return empty promptly, not crash.
# ==============================================================================
# Regression gate for: callers that loop on readLine() after the peer closes
# must see an empty string immediately, not a dereference crash or a hang.
# This is the post-close contract the caller uses to detect "connection gone".

fn test_read_after_peer_close_returns_empty(): void =>
  print("test_read_after_peer_close_returns_empty: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var clientStream: QuicStream = client.openStream()
  clientStream.writeLine("ping")
  var serverStream: QuicStream = serverConn.acceptStream()
  var ping: str = serverStream.readLine()
  assert(ping == "ping", $"server should see 'ping', got '{ping}'")

  serverStream.writeLine("pong")
  var pong: str = clientStream.readLine()
  assert(pong == "pong", $"client should see 'pong', got '{pong}'")

  # Server closes the stream (FIN) and the connection.
  serverStream.close()
  serverConn.close()
  server.close()

  # Give the close a moment to propagate to the client's I/O thread.
  Time.sleep(200)

  # Subsequent reads on the client stream must return empty, not hang or crash.
  # Use a spawned poll so a regression fails in bounded time.
  resetBg()
  var h: int = & pendingReadLineBg(clientStream)
  assert(waitForBg(3000l),
    "readLine() after peer close did not return within 3s")
  assert(bgResultStr == "",
    $"readLine() after peer close returned '{bgResultStr}', expected empty")
  h ~

  client.close()
  print("PASS\n")

# ==============================================================================
# Test 10: writes after close must not crash and must report not-written.
# ==============================================================================
# Regression gate for: write() on a closed connection must return 0 bytes,
# not crash on a null internal pointer, not deadlock on the command queue.

fn test_write_after_close_is_safe(): void =>
  print("test_write_after_close_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var clientStream: QuicStream = client.openStream()
  clientStream.writeLine("first")
  var serverStream: QuicStream = serverConn.acceptStream()
  var first: str = serverStream.readLine()
  assert(first == "first", $"server should see 'first', got '{first}'")

  # Close the client; subsequent writes on the stream must be a no-op.
  client.close()
  Time.sleep(100)

  var payload: byte[] = "after-close".toBytes()
  var wrote: int = clientStream.write(payload)
  assert(wrote == 0,
    $"write() after close should return 0, got {wrote}")

  serverStream.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 11: reconnect after peer close on the same listener.
# ==============================================================================
# Regression gate for long-lived callers: when the server gracefully closes a
# connection, the client must be able to open a fresh connection to the SAME
# listener and resume work. This is the pattern any "reconnecting RPC client"
# must use because the SDK does not yet offer connectWithRetry or an explicit
# reconnect(). It also exercises listener.accept() across multiple connection
# lifetimes, which the old global-registry lifecycle was known to mishandle.

fn test_reconnect_after_peer_close(): void =>
  print("test_reconnect_after_peer_close: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  # Round 1: connect, exchange, server closes.
  var c1: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var s1: QuicConnection = server.accept()
  var cs1: QuicStream = c1.openStream()
  cs1.writeLine("round-1")
  var ss1: QuicStream = s1.acceptStream()
  var m1: str = ss1.readLine()
  assert(m1 == "round-1", $"round 1: expected 'round-1', got '{m1}'")
  ss1.close()
  s1.close()
  # Server side has gone away; client must notice promptly.
  var r1deadline: long = Time.now().millis() + 2000l
  while !c1.isClosed() =>
    if Time.now().millis() >= r1deadline =>
      assert(false, "client did not observe peer close within 2s (round 1)")
    Time.sleep(50)
  c1.close()

  # Round 2: fresh connection to the same listener must succeed and work.
  var c2: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var s2: QuicConnection = server.accept()
  var cs2: QuicStream = c2.openStream()
  cs2.writeLine("round-2")
  var ss2: QuicStream = s2.acceptStream()
  var m2: str = ss2.readLine()
  assert(m2 == "round-2", $"round 2: expected 'round-2', got '{m2}'")
  ss2.close()
  s2.close()
  c2.close()

  server.close()
  print("PASS\n")

# ==============================================================================
# Test 12: concurrent parked readers must ALL wake on abrupt drop.
# ==============================================================================
# Regression gate for "only one stream woke" bugs. If the cleanup path uses
# COND_SIGNAL instead of COND_BROADCAST, or only iterates over a subset of
# streams, one reader will wake and the other will hang. Both streams must
# observe the closed state within bounded time.

fn parkedReader1Bg(stream: QuicStream): int =>
  var s: str = stream.readLine()
  bgResultStr = s
  bgDone = true
  return 0

fn parkedReader2Bg(stream: QuicStream): int =>
  var s: str = stream.readLine()
  bg2ResultStr = s
  bg2Done = true
  return 0

fn test_concurrent_readers_wake_on_abrupt_drop(): void =>
  print("test_concurrent_readers_wake_on_abrupt_drop: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Two streams, each with an initial greeting so both sides have real
  # stream objects. Server drains greetings but never writes back.
  var cs1: QuicStream = client.openStream()
  cs1.writeLine("s1-hi")
  var cs2: QuicStream = client.openStream()
  cs2.writeLine("s2-hi")

  var ss1: QuicStream = serverConn.acceptStream()
  var ss2: QuicStream = serverConn.acceptStream()
  # Stream-ID order is not guaranteed; drain both in whatever order they arrive.
  var g1: str = ss1.readLine()
  var g2: str = ss2.readLine()
  var gotS1: bool = (g1 == "s1-hi" || g2 == "s1-hi")
  var gotS2: bool = (g1 == "s2-hi" || g2 == "s2-hi")
  assert(gotS1 && gotS2, $"server should see both greetings, got '{g1}' and '{g2}'")

  # Park both client readers concurrently.
  var h1: int = & parkedReader1Bg(cs1)
  var h2: int = & parkedReader2Bg(cs2)

  # Give both threads time to reach their COND_WAIT.
  Time.sleep(300)

  # Abrupt server drop. Both readers must wake via the idle-timer exit path.
  serverConn.quicTestDropSocket()

  var deadline: long = Time.now().millis() + 2500l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"concurrent readers did not both wake within 2.5s: r1={bgDone} r2={bg2Done}")
    Time.sleep(50)

  h1 ~
  h2 ~

  ss1.close()
  ss2.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 13: reconnect after abrupt drop — the skynet recovery scenario.
# ==============================================================================
# Regression gate for long-lived callers that must survive a peer restart.
# The client-side socket is dropped (simulates the client process or its
# network path dying), the listener stays up (the SIBLING service survived),
# the client discards the dead handle and opens a fresh connection to the
# same listener.
#
# We drop the CLIENT socket rather than the server socket because server
# connections share the listener's UDP fd — shutting down a server
# connection's fd would also shut down the whole listener. Dropping the
# client socket kills exactly one endpoint and keeps the listener
# independently alive for round 2, which is what matters.

fn test_reconnect_after_abrupt_drop(): void =>
  print("test_reconnect_after_abrupt_drop: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  # Round 1: normal conn + exchange.
  var c1: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var s1: QuicConnection = server.accept()
  var cs1: QuicStream = c1.openStream()
  cs1.writeLine("round-1")
  var ss1: QuicStream = s1.acceptStream()
  var m1: str = ss1.readLine()
  assert(m1 == "round-1", $"round 1: expected 'round-1', got '{m1}'")

  # Abruptly drop the CLIENT-side socket of round-1. No CONNECTION_CLOSE.
  # The client will hit its idle timer because nothing can be sent or
  # received on its dead fd.
  c1.quicTestDropSocket()

  var rd: long = Time.now().millis() + 2500l
  while !c1.isClosed() =>
    if Time.now().millis() >= rd =>
      assert(false, "client did not observe abrupt drop within 2.5s")
    Time.sleep(50)

  # Discard the dead handles.
  cs1.close()
  ss1.close()
  c1.close()
  s1.close()

  # Round 2: fresh connection to the same listener. Real skynet case: the
  # listener survived; only the per-connection state was nuked. This must
  # succeed and the round trip must work end-to-end.
  var c2: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  assert(!c2.isClosed(), "round 2 connect failed")
  var s2: QuicConnection = server.accept()
  var cs2: QuicStream = c2.openStream()
  cs2.writeLine("round-2")
  var ss2: QuicStream = s2.acceptStream()
  var m2: str = ss2.readLine()
  assert(m2 == "round-2", $"round 2: expected 'round-2', got '{m2}'")

  cs2.close()
  ss2.close()
  c2.close()
  s2.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 14: openStream on a dead connection must not crash.
# ==============================================================================
# Regression gate for API safety under partial failure: a caller that holds a
# dead connection handle and calls openStream() on it must get a closed stream
# back, not a segfault or a hang on the command queue.

fn test_openstream_after_abrupt_drop_is_safe(): void =>
  print("test_openstream_after_abrupt_drop_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Confirm live before we drop.
  var warmup: QuicStream = client.openStream()
  warmup.writeLine("warmup")
  var wss: QuicStream = serverConn.acceptStream()
  var warm: str = wss.readLine()
  assert(warm == "warmup", $"server should see 'warmup', got '{warm}'")
  warmup.close()
  wss.close()

  # Abrupt drop and wait for client to notice.
  serverConn.quicTestDropSocket()
  var deadline: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false, "client did not observe abrupt drop within 2.5s")
    Time.sleep(50)

  # Now attempt openStream on the dead connection. Must not crash.
  # Must return a stream whose isClosed() is true.
  var deadStream: QuicStream = client.openStream()
  assert(deadStream.isClosed(),
    "openStream on a dead connection must return an already-closed stream")

  # write() on the dead stream must also be a safe no-op.
  var data: byte[] = "post-drop".toBytes()
  var wrote: int = deadStream.write(data)
  assert(wrote == 0,
    $"write() on dead stream must return 0, got {wrote}")

  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 15: abrupt-drop churn — 10 cycles must not leak or corrupt state.
# ==============================================================================
# Cumulative regression gate for the cleanup path on the abrupt-failure branch.
# Exercises the full (bind, connect, exchange, abrupt-drop, wait-for-close,
# dispose) sequence many times in a row on the same listener to surface
# cumulative memory/state leaks or mutex/fd corruption across cycles.

fn test_abrupt_drop_churn(): void =>
  print("test_abrupt_drop_churn: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  for var i: int = 0; i < 5; i++ =>
    var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
    assert(!c.isClosed(), $"cycle {i}: connect failed")
    var s: QuicConnection = server.accept()

    var cs: QuicStream = c.openStream()
    cs.writeLine($"cycle-{i}")
    var ss: QuicStream = s.acceptStream()
    var m: str = ss.readLine()
    assert(m == $"cycle-{i}", $"cycle {i}: expected 'cycle-{i}', got '{m}'")

    # Drop the client socket so the listener survives across cycles.
    c.quicTestDropSocket()

    var rd: long = Time.now().millis() + 2500l
    while !c.isClosed() =>
      if Time.now().millis() >= rd =>
        assert(false, $"cycle {i}: client did not observe drop within 2.5s")
      Time.sleep(50)

    cs.close()
    ss.close()
    c.close()
    s.close()

  server.close()
  print("PASS\n")

# ==============================================================================
# Test 16: listener.close() must tear down its server-side connections.
# ==============================================================================
# Regression gate for the sweep_closed_server_connections path. When the
# listener is closed, every server connection it's holding must be marked
# closed in bounded time — otherwise long-running server-side threads holding
# those references will park forever on reads or accepts.

fn test_listener_close_tears_down_server_conns(): void =>
  print("test_listener_close_tears_down_server_conns: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(800)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up so both sides have live state.
  var cs: QuicStream = client.openStream()
  cs.writeLine("warm")
  var ss: QuicStream = serverConn.acceptStream()
  var warm: str = ss.readLine()
  assert(warm == "warm", $"server should see 'warm', got '{warm}'")

  # Close the listener. Its server connections must be torn down.
  server.close()

  # serverConn was held only as an accepted handle; it must flip closed
  # within a bounded slack window (sweep interval is ~50ms, idleTimeout is
  # 800ms — a 2.5s envelope is plenty for the whole teardown).
  var sd: long = Time.now().millis() + 2500l
  while !serverConn.isClosed() =>
    if Time.now().millis() >= sd =>
      assert(false,
        "serverConn.isClosed() did not flip within 2.5s of listener close")
    Time.sleep(50)

  # Client should also notice via its idle timer.
  var cd: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= cd =>
      assert(false,
        "client.isClosed() did not flip within 2.5s of listener close")
    Time.sleep(50)

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  print("PASS\n")

# ==============================================================================
# Test 17: stream.close() after abrupt connection drop must be safe.
# ==============================================================================
# Regression gate for stream lifecycle under partial failure: after the
# underlying connection has been abruptly dropped, calling stream.close()
# — and calling it again — must not crash, deadlock, or double-free the
# stream internal state.

fn test_stream_close_after_abrupt_drop_is_safe(): void =>
  print("test_stream_close_after_abrupt_drop_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("hi")
  var ss: QuicStream = serverConn.acceptStream()
  var hi: str = ss.readLine()
  assert(hi == "hi", $"server should see 'hi', got '{hi}'")

  # Abruptly drop the client socket and wait for the connection to notice.
  client.quicTestDropSocket()
  var deadline: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false, "client did not observe abrupt drop within 2.5s")
    Time.sleep(50)

  # The stream belongs to a dead connection. close() must be safe, and
  # repeated calls must also be safe.
  cs.close()
  cs.close()
  cs.close()

  assert(cs.isClosed(), "stream must report closed after connection drop")

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 18: readExact must return what's available and exit when peer dies.
# ==============================================================================
# Regression gate for the readExact path: when the stream gets fewer bytes
# than requested because the peer died, readExact must return promptly with
# the partial data (possibly empty), not hang waiting for bytes that will
# never arrive. The docs say "Returns fewer than n bytes only if the stream
# closes prematurely" — this test enforces the bounded-time portion.

fn readExactBg(stream: QuicStream, n: int): int =>
  var start: Time = Time.now()
  var got: byte[] = stream.readExact(n)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = got.length
  bgDone = true
  return 0

fn test_readexact_bounded_when_peer_drops(): void =>
  print("test_readexact_bounded_when_peer_drops: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Client opens a stream and sends a greeting so the server sees it.
  var cs: QuicStream = client.openStream()
  cs.writeLine("hello")
  var ss: QuicStream = serverConn.acceptStream()
  var greet: str = ss.readLine()
  assert(greet == "hello", $"server should see 'hello', got '{greet}'")

  # Server writes 5 bytes of a 100-byte payload the client is waiting for,
  # then abruptly drops. Client's readExact(100) must return within bound
  # with whatever partial data arrived (or zero if nothing).
  var partial: byte[] = "01234".toBytes()
  ss.write(partial)

  # Give the partial bytes time to reach the client.
  Time.sleep(200)

  var h: int = & readExactBg(cs, 100)

  # Let the reader park on the remaining 95 bytes.
  Time.sleep(200)

  # Drop the client socket so no more bytes can arrive.
  client.quicTestDropSocket()

  assert(waitForBg(2500l),
    "readExact did not return within 2.5s of abrupt drop")

  # We expect the reader to report fewer than 100 bytes (0 to 5 is OK —
  # exact count depends on whether the partial data landed before the drop).
  assert(bgResultInt < 100,
    $"readExact should have returned < 100 bytes, got {bgResultInt}")
  h ~

  ss.close()
  serverConn.close()
  server.close()
  cs.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 19: listener.close() must wake a parked listener.accept().
# ==============================================================================
# Regression gate for the LISTENER's accept_cond (distinct from the connection
# accept_stream_cond tested in tests 7 and 8). A server thread parked on
# listener.accept() waiting for a client must wake promptly when the listener
# itself is closed — otherwise a process trying to shut down cleanly will
# hang on its own acceptor threads.

fn pendingListenerAcceptBg(listener: QuicListener): int =>
  var c: QuicConnection = listener.accept()
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_listener_close_wakes_pending_accept(): void =>
  print("test_listener_close_wakes_pending_accept: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)

  # Park an acceptor thread. No client will connect.
  var h: int = & pendingListenerAcceptBg(server)

  # Give the acceptor time to reach its COND_WAIT.
  Time.sleep(300)

  # Close the listener. The parked accept must wake within bounded time.
  server.close()

  assert(waitForBg(3000l),
    "listener.accept() did not wake within 3s of listener.close()")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 20: readAll must exit in bounded time when the peer dies mid-transfer.
# ==============================================================================
# Regression gate for the readAll code path (distinct from read and readExact).
# readAll is documented as "Read until stream is closed by peer" — if the
# peer dies without closing the stream, readAll must observe the connection
# close via the idle timer and return whatever data has accumulated, not
# hang forever.

fn readAllBg(stream: QuicStream): int =>
  var start: Time = Time.now()
  var got: byte[] = stream.readAll()
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = got.length
  bgDone = true
  return 0

fn test_readall_bounded_when_peer_drops(): void =>
  print("test_readall_bounded_when_peer_drops: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Establish the stream with a greeting so both sides see the stream.
  var cs: QuicStream = client.openStream()
  cs.writeLine("hi")
  var ss: QuicStream = serverConn.acceptStream()
  var hi: str = ss.readLine()
  assert(hi == "hi", $"server should see 'hi', got '{hi}'")

  # Park client in readAll — will wait until the stream is closed.
  var h: int = & readAllBg(cs)

  Time.sleep(200)

  # Abruptly drop the client socket. Client must observe via idle timer
  # and readAll must return.
  client.quicTestDropSocket()

  assert(waitForBg(2500l),
    "readAll did not return within 2.5s of abrupt drop")
  h ~

  ss.close()
  serverConn.close()
  server.close()
  cs.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 21: raw write() loop must exit cleanly when the peer drops mid-stream.
# ==============================================================================
# Regression gate for the write path under concurrent teardown. A writer
# thread spinning on write(byte[]) while the connection is abruptly dropped
# must either: (a) observe isClosed() on its next check, or (b) have its
# in-flight command completed with error by the cleanup path. It must not
# deadlock on the command queue, and it must not use-after-free on the
# write_bufs list that cleanup frees in its exit pass.

fn rawWriteLoopBg(stream: QuicStream): int =>
  var iterations: int = 0
  for var i: int = 0; i < 200; i++ =>
    if stream.isClosed() =>
      break
    var data: byte[] = $"chunk-{i}-padding-padding".toBytes()
    var wrote: int = stream.write(data)
    iterations = i + 1
    Time.sleep(5)
  bgResultInt = iterations
  bgDone = true
  return 0

fn test_raw_write_loop_during_abrupt_drop(): void =>
  print("test_raw_write_loop_during_abrupt_drop: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Fresh stream, no warmup exchange — the writer will start flooding
  # immediately and the server won't bother to read.
  var cs: QuicStream = client.openStream()
  var h: int = & rawWriteLoopBg(cs)

  # Let a handful of writes complete before we yank the rug.
  Time.sleep(100)

  # Abrupt drop. Must not hang the writer, must not UAF.
  client.quicTestDropSocket()

  assert(waitForBg(2500l),
    $"write loop did not exit within 2.5s of abrupt drop (iterations={bgResultInt})")
  assert(bgResultInt > 0,
    "at least one write should have completed before the drop")
  h ~

  serverConn.close()
  server.close()
  cs.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 22: handshake_timeout must tightly bound a dead-peer connect.
# ==============================================================================
# Regression gate for the settings.handshake_timeout wiring. Prior to that
# fix the handshake was only bounded by ngtcp2's PTO probe sequence, which
# could take ~3s even with a 500ms idle_timeout. With the fix a connect()
# to a port where nothing responds must return within roughly idleTimeout +
# one poll cycle — well under 2x idleTimeout.

fn tightConnectBg(port: int): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(500)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgDone = true
  return 0

fn test_handshake_timeout_is_tight(): void =>
  print("test_handshake_timeout_is_tight: ")
  resetBg()

  # Bind + close to claim-and-release a free port so nothing else will
  # be listening there when the connect starts.
  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var claim: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var port: int = claim.port()
  claim.close()

  var h: int = & tightConnectBg(port)

  assert(waitForBg(2000l),
    $"connect() to dead port did not return within 2s (idleTimeout=500ms)")
  assert(bgElapsedMs <= 1500l,
    $"connect() took {bgElapsedMs}ms, expected <= 1500ms (3x idle_timeout)")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 23: two clients on the same listener — one drops, the other survives.
# ==============================================================================
# Regression gate for cross-connection isolation on a shared listener. When
# one client's per-connection state is torn down abruptly, the listener's
# routing + sweep code must not disturb any other live connection.

fn test_multiple_clients_one_drops(): void =>
  print("test_multiple_clients_one_drops: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # Both sides use a long idle timeout for this test so c2 can't idle out
  # while we poll waiting for c1 to detect its drop.
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  # Two clients on the same listener.
  var c1: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var s1: QuicConnection = server.accept()
  var c2: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var s2: QuicConnection = server.accept()

  # Round trip on both to prove they're independently live.
  var cs1: QuicStream = c1.openStream()
  cs1.writeLine("c1-hello")
  var ss1: QuicStream = s1.acceptStream()
  var g1: str = ss1.readLine()
  assert(g1 == "c1-hello", $"c1 greeting: expected 'c1-hello', got '{g1}'")

  var cs2: QuicStream = c2.openStream()
  cs2.writeLine("c2-hello")
  var ss2: QuicStream = s2.acceptStream()
  var g2: str = ss2.readLine()
  assert(g2 == "c2-hello", $"c2 greeting: expected 'c2-hello', got '{g2}'")

  # Drop c1 abruptly.
  c1.quicTestDropSocket()

  # Immediately verify c2 is unaffected — this is the actual isolation
  # assertion. Do the round trip now, BEFORE any polling window could
  # let c2's idle timer fire.
  assert(!c2.isClosed(), "c2 must remain alive immediately after c1 drop")
  cs2.writeLine("c2-after-drop")
  var after: str = ss2.readLine()
  assert(after == "c2-after-drop",
    $"c2 post-drop round trip: expected 'c2-after-drop', got '{after}'")

  # Also verify the listener still routes a brand-new stream on c2 — this
  # catches regressions where the listener's conn-list gets corrupted by
  # c1's teardown.
  var cs2b: QuicStream = c2.openStream()
  cs2b.writeLine("c2-new-stream")
  var ss2b: QuicStream = s2.acceptStream()
  var ns: str = ss2b.readLine()
  assert(ns == "c2-new-stream",
    $"c2 new stream: expected 'c2-new-stream', got '{ns}'")

  cs1.close()
  cs2.close()
  cs2b.close()
  ss1.close()
  ss2.close()
  ss2b.close()
  c1.close()
  s1.close()
  c2.close()
  s2.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 24: server writes to a dead client must exit bounded, not hang.
# ==============================================================================
# Regression gate for the server-side write path under peer death. The
# server has a live stream and the client dies without sending a close.
# Subsequent server.writeLine() calls must complete in bounded time —
# either succeeding into the void or bailing out once the server's idle
# timer fires and marks the connection closed.

fn serverWriteLoopBg(stream: QuicStream): int =>
  var iters: int = 0
  for var i: int = 0; i < 50; i++ =>
    if stream.isClosed() =>
      break
    stream.writeLine($"server-msg-{i}")
    iters = i + 1
    Time.sleep(20)
  bgResultInt = iters
  bgDone = true
  return 0

fn test_server_writes_to_dead_client(): void =>
  print("test_server_writes_to_dead_client: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Establish the stream from the client side, then hand to the server.
  var cs: QuicStream = client.openStream()
  cs.writeLine("ready")
  var ss: QuicStream = serverConn.acceptStream()
  var ready: str = ss.readLine()
  assert(ready == "ready", $"server should see 'ready', got '{ready}'")

  # Park the server in a write loop.
  var h: int = & serverWriteLoopBg(ss)

  # Let a handful of writes land.
  Time.sleep(100)

  # Client dies abruptly.
  client.quicTestDropSocket()

  # Server write loop must exit within idle_timeout + slack.
  assert(waitForBg(3000l),
    $"server write loop did not exit within 3s (iterations={bgResultInt})")
  h ~

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 25: unidirectional stream under abrupt drop.
# ==============================================================================
# Regression gate for the unidirectional stream code path. All the prior
# tests use bidi streams. Uni streams have a separate code path
# (is_uni flag, different flow control direction) and must also handle
# abrupt peer death without crashing.

fn test_uni_stream_abrupt_drop_is_safe(): void =>
  print("test_uni_stream_abrupt_drop_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Open a unidirectional stream (client → server, no response).
  var cs: QuicStream = client.openUnidirectionalStream()
  assert(cs.isUnidirectional(), "stream should be unidirectional")
  cs.writeLine("uni-hello")

  # Drain it on the server side.
  var ss: QuicStream = serverConn.acceptStream()
  var msg: str = ss.readLine()
  assert(msg == "uni-hello", $"server should see 'uni-hello', got '{msg}'")

  # Drop the client. Both sides must notice and close without crashing.
  client.quicTestDropSocket()

  var deadline: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false, "client did not observe abrupt drop within 2.5s (uni)")
    Time.sleep(50)

  # Stream ops after drop must be safe.
  cs.close()
  cs.close()
  assert(cs.isClosed(), "uni stream must be closed after connection drop")

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 26: remoteAddress() on a closed connection must not crash.
# ==============================================================================
# Regression gate for getter API safety. Long-lived code that logs the
# remote address of a connection may be holding a handle whose underlying
# state has already been torn down. remoteAddress() must return a valid
# (possibly empty) string, not dereference freed memory.

fn test_remote_address_on_closed_conn_is_safe(): void =>
  print("test_remote_address_on_closed_conn_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Sanity: before close, the remote address should start with 127.0.0.1:.
  var aliveAddr: str = client.remoteAddress()
  assert(aliveAddr.startsWith("127.0.0.1:"),
    $"live client remote: expected '127.0.0.1:*', got '{aliveAddr}'")

  client.close()
  serverConn.close()
  server.close()

  # After close, the call must be safe and idempotent. The exact return
  # value is implementation-defined (empty or the stashed last-known value).
  var deadAddr: str = client.remoteAddress()
  var deadAddr2: str = client.remoteAddress()
  assert(deadAddr.length >= 0, "remoteAddress after close must return a string")
  assert(deadAddr2.length >= 0, "remoteAddress after close (2nd call) must be safe")
  print("PASS\n")

# ==============================================================================
# Test 27: partial readLine (bytes without newline) must exit bounded.
# ==============================================================================
# Regression gate for the readLine path when the peer buffers some bytes
# and then dies without sending a newline. The read MUST return in bounded
# time with what it has (or empty), not hang waiting for a newline that
# will never arrive.

fn test_partial_readline_bounded_when_peer_dies(): void =>
  print("test_partial_readline_bounded_when_peer_dies: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Establish the stream.
  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"server should see 'open', got '{open_}'")

  # Server writes a partial line — bytes but NO newline.
  var partial: byte[] = "unterm".toBytes()
  ss.write(partial)

  # Give the partial bytes time to reach the client's recv_buf.
  Time.sleep(200)

  # Park the client on readLine. It must park because the newline is missing.
  var h: int = & pendingReadLineBg(cs)

  Time.sleep(200)

  # Drop the client socket. The client must observe the drop via its idle
  # timer and wake the parked readLine in bounded time.
  client.quicTestDropSocket()

  assert(waitForBg(2500l),
    "partial readLine did not return within 2.5s of abrupt drop")
  h ~

  ss.close()
  serverConn.close()
  server.close()
  cs.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 28: stream budget exhaustion must fail safely, not hang.
# ==============================================================================
# Regression gate for openStream() under ngtcp2's stream-id budget. The
# default initial_max_streams_bidi is 100. Opening 100 streams without
# closing them exhausts the budget; subsequent openStream() calls must
# return a closed stream (or something caller-checkable) in bounded time,
# not block forever.

fn test_stream_budget_exhaustion_is_safe(): void =>
  print("test_stream_budget_exhaustion_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # Small budget so the test runs fast.
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000).setMaxBidiStreams(8)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Open streams up to the peer's advertised limit. Don't close them
  # — the budget replenishes on close, so keeping them open holds it down.
  var opened: QuicStream[] = {}
  for var i: int = 0; i < 8; i++ =>
    var s: QuicStream = client.openStream()
    assert(!s.isClosed(), $"openStream {i} should succeed within the budget")
    # Touch the stream so it's actually live on the wire.
    s.writeLine($"stream-{i}")
    opened.push(s)

  # Next openStream is outside the budget. It must not hang. The test's
  # wall deadline is enforced by the runner, but we also bound it via a
  # background thread so a regression fails with a clear assertion.
  resetBg()
  var h: int = & pendingOpenStreamBg(client)

  # Retry window in QUIC_CMD_OPEN_BIDI is ~2s — allow 3s wall to cover it.
  assert(waitForBg(3000l),
    "openStream beyond budget did not return within 3s (ngtcp2 STREAM_ID_BLOCKED)")
  h ~

  # Clean up the streams we held open.
  for var i: int = 0; i < 8; i++ =>
    opened[i].close()

  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 29: concurrent writers on one stream during abrupt drop.
# ==============================================================================
# Regression gate for the cmd queue + write_bufs mutex discipline under
# multi-writer contention. Two threads pound writes on the same stream
# while the peer dies abruptly mid-flight. Both writers must exit in
# bounded time, neither should UAF or deadlock.

fn writer1LoopBg(stream: QuicStream): int =>
  var iters: int = 0
  for var i: int = 0; i < 100; i++ =>
    if stream.isClosed() =>
      break
    stream.writeLine($"w1-{i}")
    iters = i + 1
    Time.sleep(5)
  bgResultInt = iters
  bgDone = true
  return 0

fn writer2LoopBg(stream: QuicStream): int =>
  var iters: int = 0
  for var i: int = 0; i < 100; i++ =>
    if stream.isClosed() =>
      break
    stream.writeLine($"w2-{i}")
    iters = i + 1
    Time.sleep(5)
  bg2ResultStr = $"{iters}"
  bg2Done = true
  return 0

fn test_concurrent_writers_during_abrupt_drop(): void =>
  print("test_concurrent_writers_during_abrupt_drop: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  # Warmup: a single server-side accept so the stream is fully live.
  cs.writeLine("hi")
  var ss: QuicStream = serverConn.acceptStream()
  var hi: str = ss.readLine()
  assert(hi == "hi", $"server should see 'hi', got '{hi}'")

  # Two writers pound the same stream.
  var h1: int = & writer1LoopBg(cs)
  var h2: int = & writer2LoopBg(cs)

  # Let a handful of writes from each thread land before we drop.
  Time.sleep(100)

  # Abrupt drop.
  client.quicTestDropSocket()

  # Both writers must exit in bounded time.
  var deadline: long = Time.now().millis() + 3000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"writer loops did not both exit within 3s: w1={bgDone} w2={bg2Done}")
    Time.sleep(50)

  h1 ~
  h2 ~

  ss.close()
  serverConn.close()
  server.close()
  cs.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 30: double close must be idempotent.
# ==============================================================================
# Regression gate for: calling close() twice on a connection or listener must
# not crash or double-free. The refcount-driven dispose path should absorb it.

fn test_double_close_is_safe(): void =>
  print("test_double_close_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connect($"127.0.0.1:{port}")
  var serverConn: QuicConnection = server.accept()

  client.close()
  client.close() # must not crash

  serverConn.close()
  serverConn.close() # must not crash

  server.close()
  server.close() # must not crash

  print("PASS\n")

# ==============================================================================
# Test 31: listener.accept() AFTER listener.close() must return bounded.
# ==============================================================================
# Regression gate for the close-then-accept ordering on the listener's
# accept_cond. Test 19 covers accept-then-close (parked acceptor wakes); this
# covers the reverse: the listener is already closed when a caller invokes
# accept(). The while-loop guard must see !running and exit immediately
# without ever parking on the cond, otherwise callers shutting down get
# stuck on the condvar.

fn test_listener_accept_after_close_is_bounded(): void =>
  print("test_listener_accept_after_close_is_bounded: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  server.close()

  # Now call accept() on the already-closed listener from a bg thread so
  # a regression fails loudly instead of hanging.
  var h: int = & pendingListenerAcceptBg(server)

  assert(waitForBg(2000l),
    "listener.accept() after close did not return within 2s")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 32: bind with a missing cert file must fail clean, not crash.
# ==============================================================================
# Regression gate for the server-side TLS init error path. If the cert file
# is missing, SSL_CTX loading fails and quic_listener_create returns NULL.
# The Sindarin caller then holds a null listener handle; calling port() on
# it must return 0 and calling close() must be a safe no-op. A regression
# that dereferences the null C pointer crashes the test process here.

fn test_bind_missing_cert_file_fails_clean(): void =>
  print("test_bind_missing_cert_file_fails_clean: ")

  var listener: QuicListener = QuicListener.bind(
    ":0",
    "tests/net/does_not_exist_cert.pem",
    "tests/net/does_not_exist_key.pem")

  # C side returns NULL → Sindarin receives a null ref. port() / close()
  # must handle that without dereferencing.
  var p: int = listener.port()
  assert(p == 0, $"bind with missing cert should report port=0, got {p}")
  listener.close()
  listener.close()
  print("PASS\n")

# ==============================================================================
# Test 33: bind with a malformed address must fail clean, not crash.
# ==============================================================================
# Regression gate for parse_address on the bind path. Garbage in the
# address string must fail before any socket/SSL state is allocated and
# return a null handle.

fn test_bind_with_malformed_address_fails_clean(): void =>
  print("test_bind_with_malformed_address_fails_clean: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  # parse_address rejects empty host+port combinations and non-numeric ports.
  var l1: QuicListener = QuicListener.bind("", cert_path, key_path)
  assert(l1.port() == 0, "bind('') should report port=0")
  l1.close()

  var l2: QuicListener = QuicListener.bind("not_a_host:abc", cert_path, key_path)
  assert(l2.port() == 0, "bind('not_a_host:abc') should report port=0")
  l2.close()
  print("PASS\n")

# ==============================================================================
# Test 34: bind(":0") must report a real, non-zero port.
# ==============================================================================
# Regression gate for the ephemeral port readback path (getsockname after
# bind). Callers that later advertise the listener's port to peers depend
# on this invariant — a zero return would be silently indistinguishable
# from a failed bind.

fn test_bind_zero_port_reports_real_port(): void =>
  print("test_bind_zero_port_reports_real_port: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var p: int = server.port()
  assert(p > 0, $"bind(':0') should return a real port, got {p}")
  assert(p < 65536, $"bind(':0') port out of range, got {p}")
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 35: connect() to a TCP listener must bound via handshake timer.
# ==============================================================================
# Regression gate for "wrong protocol" startup races: a client aiming at a
# port that is live but speaks a different protocol (ops misconfiguration,
# LB pointing at a TCP-only target) must bound the handshake via the idle
# timer. UDP packets to a TCP-only port draw ICMP port-unreachable or are
# silently black-holed; either way the client must give up in bounded time.

fn connectToTcpBg(port: int): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(800)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_connect_to_tcp_listener_is_bounded(): void =>
  print("test_connect_to_tcp_listener_is_bounded: ")
  resetBg()

  # Stand up a TCP listener on an ephemeral port. The QUIC client will try
  # to handshake at that port; no UDP socket is bound there, so the
  # handshake must fail via the idle timer (or kernel ECONNREFUSED on the
  # connected UDP socket).
  var tcp: TcpListener = TcpListener.bind(":0")
  var port: int = tcp.port()

  var h: int = & connectToTcpBg(port)

  assert(waitForBg(3000l),
    "connect() to TCP port did not return within 3s (idleTimeout=800ms)")
  assert(bgElapsedMs <= 2500l,
    $"connect() to TCP port took {bgElapsedMs}ms, expected <= 2500ms")
  assert(bgResultInt == 0,
    "connect() to TCP port should return a closed handle")
  h ~
  tcp.dispose()
  print("PASS\n")

# ==============================================================================
# Test 36: connect() to an unreachable IP must bound.
# ==============================================================================
# Regression gate for the "no route / ICMP unreachable / black hole" failure
# class. 192.0.2.1 is TEST-NET-1 (RFC 5737), reserved for documentation and
# guaranteed never to route to a real host. A connect() against it must
# bound via the handshake/idle timer — long-lived callers must not wedge
# indefinitely on a misrouted address.

fn connectToUnreachableBg(): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)
  var c: QuicConnection = QuicConnection.connectWith("192.0.2.1:4433", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_connect_to_unreachable_ip_is_bounded(): void =>
  print("test_connect_to_unreachable_ip_is_bounded: ")
  resetBg()

  var h: int = & connectToUnreachableBg()

  # Generous slack: depending on host routing, the kernel may return
  # ENETUNREACH immediately on the initial sendto, or the connect may
  # have to ride out the full idle_timeout. Either outcome is acceptable
  # as long as we return within a sane envelope.
  assert(waitForBg(4000l),
    "connect() to unreachable IP did not return within 4s")
  assert(bgElapsedMs <= 3500l,
    $"connect() to unreachable IP took {bgElapsedMs}ms, expected <= 3500ms")
  assert(bgResultInt == 0,
    "connect() to unreachable IP should return a closed handle")
  h ~
  print("PASS\n")

# ==============================================================================
# Test 37: connect() with a malformed address must return bounded, not crash.
# ==============================================================================
# Regression gate for parse_address on the client path. A caller that
# passes garbage to connect() should get a closed (or null) handle back
# promptly — never a crash and never a blocking DNS lookup that could
# hang for tens of seconds.

fn connectMalformedBg(addr: str): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)
  var c: QuicConnection = QuicConnection.connectWith(addr, cfg)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_connect_with_malformed_address(): void =>
  print("test_connect_with_malformed_address: ")
  resetBg()

  # Non-numeric port: parse_address must reject.
  var h: int = & connectMalformedBg("127.0.0.1:abc")
  assert(waitForBg(3000l),
    "connect(malformed) did not return within 3s")
  assert(bgResultInt == 0,
    "connect(malformed) should return a closed handle")
  h ~

  resetBg()
  # Empty string: must also bound and not crash.
  var h2: int = & connectMalformedBg("")
  assert(waitForBg(3000l),
    "connect('') did not return within 3s")
  assert(bgResultInt == 0,
    "connect('') should return a closed handle")
  h2 ~
  print("PASS\n")

# ==============================================================================
# Test 38: migrate() on a closed connection must be a safe no-op.
# ==============================================================================
# Regression gate for post-close API safety of the migrate path. migrate()
# checks ci->closed before touching the ngtcp2 state machine, but a
# regression that bypasses that check (or dereferences ci after close)
# would crash the process on a harmless-looking logging call.

fn test_migrate_on_closed_conn_is_safe(): void =>
  print("test_migrate_on_closed_conn_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  client.close()
  Time.sleep(100)

  # Migrate on a closed client — must be a no-op, not a crash.
  client.migrate("127.0.0.1:0")
  client.migrate("127.0.0.1:0")

  # Migrate with a malformed address on a closed conn — also safe.
  client.migrate("not_a_host:abc")

  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 39: resumptionToken() on a closed connection must be safe.
# ==============================================================================
# Regression gate for: logging/telemetry callers that grab a resumption
# token off a connection they're about to drop. Must return a valid
# byte[] (possibly empty), never crash on a null ci.

fn test_resumption_token_on_closed_conn_is_safe(): void =>
  print("test_resumption_token_on_closed_conn_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Pre-close: the call must not crash even if no token has been issued.
  var preToken: byte[] = client.resumptionToken()
  assert(preToken.length >= 0,
    "resumptionToken() pre-close must return a byte[]")

  client.close()
  Time.sleep(100)

  # Post-close: two calls in a row, both must be safe.
  var t1: byte[] = client.resumptionToken()
  var t2: byte[] = client.resumptionToken()
  assert(t1.length >= 0, "resumptionToken() after close must return a byte[]")
  assert(t2.length >= 0, "resumptionToken() after close (2nd) must be safe")

  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 40: connectEarly() with a garbage token must bound.
# ==============================================================================
# Regression gate for the 0-RTT code path's robustness. A caller that
# hands connectEarly() a bogus (corrupted, stale, or fabricated) token
# must get a bounded handshake — the server will reject the early data
# and the connection must either fall back to 1-RTT or fail cleanly in
# bounded time. It must NOT crash on the token's bytes and must NOT
# hang forever on the wire.

fn connectEarlyBg(port: int, token: byte[]): int =>
  var start: Time = Time.now()
  var c: QuicConnection = QuicConnection.connectEarly($"127.0.0.1:{port}", token)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_connect_early_with_garbage_token_is_bounded(): void =>
  print("test_connect_early_with_garbage_token_is_bounded: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var port: int = server.port()

  # 64 bytes of arbitrary non-zero pattern — enough to look like a token to
  # the wrapper layer but guaranteed not to decrypt as anything the server
  # recognises.
  var garbage: byte[] = "not_a_valid_resumption_token_just_garbage_bytes_for_the_test_ok!".toBytes()

  var h: int = & connectEarlyBg(port, garbage)

  # Accept either outcome: the handshake completes (server ignores early
  # data and falls back to 1-RTT) or the handshake fails. Only the bound
  # is enforced here. The default idle_timeout is 30s for connectEarly,
  # but a successful handshake with a live listener should complete in
  # much less than that — ~1s is comfortable slack.
  assert(waitForBg(5000l),
    "connectEarly(garbage_token) did not return within 5s")
  h ~

  server.close()
  print("PASS\n")

# ==============================================================================
# Test 41: serve() must return when the connection drops.
# ==============================================================================
# Regression gate for the conn.serve(handler) main loop. serve() parks on
# acceptStream() inside a while(!isClosed()) loop; when the connection
# goes away, the parked accept must wake AND the outer isClosed() check
# must see the flag, so the serve() call returns. A regression that
# leaks the acceptor thread (serve never returns) leaves the server
# process unable to shut down cleanly.

fn noopStreamHandler(stream: QuicStream): int =>
  stream.close()
  return 0

fn serveBg(conn: QuicConnection): int =>
  var start: Time = Time.now()
  conn.serve(noopStreamHandler)
  bgElapsedMs = Time.now().diff(start)
  bgDone = true
  return 0

fn test_serve_returns_when_connection_drops(): void =>
  print("test_serve_returns_when_connection_drops: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Park the server in its serve loop. No streams will be opened, so
  # acceptStream() blocks until the connection dies.
  var h: int = & serveBg(serverConn)

  # Let the serve loop reach its COND_WAIT in acceptStream().
  Time.sleep(200)

  # Drop the client. Server must notice via idle timer and serve() must
  # return when isClosed() flips.
  client.quicTestDropSocket()

  assert(waitForBg(3000l),
    "serve() did not return within 3s of peer death")
  h ~

  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 42: many sequential open/close cycles must not leak or hang.
# ==============================================================================
# Cumulative regression gate for stream lifecycle on the open → exchange →
# close path. 100 open/close cycles on one connection with a small bidi
# budget forces the MAX_STREAMS credit replenishment path to run many
# times. A leak, double-free, or credit-starvation bug shows up as a
# hang or a budget-exhaustion failure midway.

fn test_many_sequential_open_close_cycles(): void =>
  print("test_many_sequential_open_close_cycles: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # Moderate budget so the 100 cycles hit the MAX_STREAMS replenishment
  # path a couple of times but not aggressively — smaller budgets were
  # observed to trip the same race class documented in
  # docs/issues/quic_persistent_rpc_burst_flake.md.
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxBidiStreams(64)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var startMs: long = Time.now().millis()

  for var i: int = 0; i < 100; i++ =>
    var cs: QuicStream = client.openStream()
    assert(!cs.isClosed(),
      $"cycle {i}: openStream returned closed stream (budget stall?)")
    cs.writeLine($"cycle-{i}")

    var ss: QuicStream = serverConn.acceptStream()
    var msg: str = ss.readLine()
    assert(msg == $"cycle-{i}", $"cycle {i}: expected 'cycle-{i}', got '{msg}'")
    ss.writeLine($"ack-{i}")

    var ack: str = cs.readLine()
    assert(ack == $"ack-{i}", $"cycle {i}: expected 'ack-{i}', got '{ack}'")

    cs.close()
    ss.close()

    # Bound the whole loop so a hang surfaces loudly.
    if Time.now().millis() - startMs > 15000l =>
      assert(false, $"sequential open/close cycles hung at i={i}")

  var totalMs: long = Time.now().millis() - startMs
  assert(totalMs < 15000l,
    $"100 open/close cycles took {totalMs}ms, expected < 15000ms")

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 43: concurrent openStream() calls on one connection must all succeed.
# ==============================================================================
# Regression gate for the command queue path in openStream under
# concurrent callers. Two threads pound openStream() on the same
# connection; every call must succeed (stream budget is 100, we open
# 8 total) and no call must return a closed handle or crash. Exercises
# quic_submit_cmd_and_wait + the I/O thread's cmd dispatcher under
# real contention.

fn concurrentOpenBg1(conn: QuicConnection): int =>
  var ok: int = 0
  for var i: int = 0; i < 4; i++ =>
    var s: QuicStream = conn.openStream()
    if !s.isClosed() =>
      ok++
      s.close()
  bgResultInt = ok
  bgDone = true
  return 0

fn concurrentOpenBg2(conn: QuicConnection): int =>
  var ok: int = 0
  for var i: int = 0; i < 4; i++ =>
    var s: QuicStream = conn.openStream()
    if !s.isClosed() =>
      ok++
      s.close()
  bg2ResultStr = $"{ok}"
  bg2Done = true
  return 0

fn test_concurrent_opens_from_one_client(): void =>
  print("test_concurrent_opens_from_one_client: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Two threads concurrently open 4 streams each on the same connection.
  var h1: int = & concurrentOpenBg1(client)
  var h2: int = & concurrentOpenBg2(client)

  var deadline: long = Time.now().millis() + 5000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"concurrent opens did not both finish within 5s: t1={bgDone} t2={bg2Done}")
    Time.sleep(50)
  h1 ~
  h2 ~

  assert(bgResultInt == 4,
    $"thread 1 opened {bgResultInt}/4 streams successfully")
  var t2count: int = bg2ResultStr.toInt()
  assert(t2count == 4,
    $"thread 2 opened {t2count}/4 streams successfully")

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 44: large payload must stream end-to-end through flow control.
# ==============================================================================
# Regression gate for the stream/connection flow control windows. A
# 256KB payload written in 256 x 1KB chunks must arrive intact on the
# other side. A bug in the MAX_STREAM_DATA / MAX_DATA frame generation
# or in the send/recv buffer accounting would either deadlock (writer
# stuck on window) or drop bytes.

fn test_write_large_payload_streams_through(): void =>
  print("test_write_large_payload_streams_through: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(15000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Build a 1 KB chunk from a repeating 16-byte pattern.
  var chunkStr: str = ""
  for var i: int = 0; i < 64; i++ =>
    chunkStr = chunkStr + "0123456789abcdef"

  var chunk: byte[] = chunkStr.toBytes()
  var chunkLen: int = chunk.length

  var cs: QuicStream = client.openStream()
  # Send a greeting so the server can accept the stream.
  cs.writeLine("big")
  var ss: QuicStream = serverConn.acceptStream()
  var greet: str = ss.readLine()
  assert(greet == "big", $"server should see 'big', got '{greet}'")

  # Client writes 256 * 1KB = 256KB.
  var totalChunks: int = 256
  var startMs: long = Time.now().millis()
  for var i: int = 0; i < totalChunks; i++ =>
    var wrote: int = cs.write(chunk)
    assert(wrote == chunkLen,
      $"chunk {i}: wrote {wrote}/{chunkLen} bytes")

  # Client signals EOF so the server's readAll returns.
  cs.close()

  # Server reads until EOF and checks total length.
  var got: byte[] = ss.readAll()
  var expected: int = totalChunks * chunkLen
  assert(got.length == expected,
    $"server received {got.length} bytes, expected {expected}")

  var elapsedMs: long = Time.now().millis() - startMs
  assert(elapsedMs < 10000l,
    $"large payload took {elapsedMs}ms to stream, expected < 10000ms")

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 45: stream handle must remain safe after its connection is closed.
# ==============================================================================
# Regression gate for stream refcount / lifecycle hazards. A caller that
# holds a QuicStream reference past the QuicConnection's scope (e.g. a
# logger stashing the stream for later diagnostic writes) must not crash
# when the connection goes away first. All stream operations must become
# safe no-ops reporting isClosed() == true.

fn test_stream_outlives_connection(): void =>
  print("test_stream_outlives_connection: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("hi")
  var ss: QuicStream = serverConn.acceptStream()
  var greet: str = ss.readLine()
  assert(greet == "hi", $"server should see 'hi', got '{greet}'")

  # Close the client connection. The Sindarin `cs` handle is still live
  # (the refcount keeps the stream struct allocated) even though its
  # owning connection is gone.
  client.close()
  Time.sleep(200)

  assert(cs.isClosed(),
    "stream must observe isClosed=true after its conn is closed")

  var payload: byte[] = "orphaned".toBytes()
  var wrote: int = cs.write(payload)
  assert(wrote == 0,
    $"write on orphaned stream should return 0, got {wrote}")

  var line: str = cs.readLine()
  assert(line == "",
    $"readLine on orphaned stream should return '', got '{line}'")

  # Repeated close must be idempotent.
  cs.close()
  cs.close()

  ss.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 46: acceptStream() on an already-closed conn must be bounded.
# ==============================================================================
# Regression gate for the close-then-accept ordering on accept_stream_cond.
# Symmetric to test 31 (listener flavour). If acceptStream's wait loop
# doesn't check ci->closed before parking, a caller that closes and then
# accepts gets wedged on a condvar that will never be broadcast again.

fn test_accept_stream_after_close_is_bounded(): void =>
  print("test_accept_stream_after_close_is_bounded: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Close serverConn BEFORE calling acceptStream.
  serverConn.close()
  Time.sleep(100)

  # Call acceptStream on the already-closed conn from a bg thread so a
  # regression fails loudly instead of wedging.
  var h: int = & pendingAcceptStreamBg(serverConn)
  assert(waitForBg(2000l),
    "acceptStream on closed conn did not return within 2s")
  assert(bgResultInt == 0,
    "acceptStream on closed conn should return a closed stream")
  h ~

  client.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 47: write(empty byte[]) must be a safe no-op.
# ==============================================================================
# Regression gate for zero-length buffer handling in the write path. An
# empty write must not crash on a null buffer pointer, must not enqueue a
# zero-length command that confuses the I/O thread, and must leave the
# stream in a state where a subsequent normal write still works.

fn test_write_empty_bytes_is_safe(): void =>
  print("test_write_empty_bytes_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("ping")
  var ss: QuicStream = serverConn.acceptStream()
  var ping: str = ss.readLine()
  assert(ping == "ping", $"expected 'ping', got '{ping}'")

  # Empty write must return a valid count (conventionally 0) and must
  # not disturb the stream.
  var empty: byte[] = {}
  var wrote: int = cs.write(empty)
  assert(wrote == 0,
    $"write(empty) should return 0, got {wrote}")

  # Subsequent normal write must still work.
  cs.writeLine("after-empty")
  var after: str = ss.readLine()
  assert(after == "after-empty", $"expected 'after-empty', got '{after}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 48: read(0) must return an empty buffer promptly.
# ==============================================================================
# Regression gate for the read(0) fast path. A caller that passes 0 for
# maxBytes (e.g. as a result of arithmetic producing 0) must not block
# forever waiting for a byte that will never be requested. Return must be
# an empty byte[] within milliseconds.

fn readZeroBg(stream: QuicStream): int =>
  var start: Time = Time.now()
  var got: byte[] = stream.read(0)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = got.length
  bgDone = true
  return 0

fn test_read_zero_bytes_returns_empty(): void =>
  print("test_read_zero_bytes_returns_empty: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("hi")
  var ss: QuicStream = serverConn.acceptStream()
  var hi: str = ss.readLine()
  assert(hi == "hi", $"expected 'hi', got '{hi}'")

  # read(0) must return within bounded time even though no data has been
  # staged from server. Bound via bg thread so a hang fails loudly.
  var h: int = & readZeroBg(cs)
  assert(waitForBg(1500l),
    "read(0) did not return within 1.5s — fast path not short-circuited")
  assert(bgResultInt == 0,
    $"read(0) returned {bgResultInt} bytes, expected 0")
  h ~

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 49: writeLine("") must send a bare newline, readable as empty.
# ==============================================================================
# Regression gate for the empty-line framing boundary. Protocols that use
# blank lines as record separators (HTTP header/body boundary, some RPC
# framings) rely on this. writeLine("") must produce a newline byte on
# the wire and the peer's readLine() must observe an empty string.

fn test_write_line_empty_string_is_safe(): void =>
  print("test_write_line_empty_string_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  # Establish the stream with a real greeting first, then the empty line,
  # then a terminator so the server knows when to stop reading.
  cs.writeLine("start")
  cs.writeLine("")
  cs.writeLine("end")

  var ss: QuicStream = serverConn.acceptStream()
  var l1: str = ss.readLine()
  assert(l1 == "start", $"line 1: expected 'start', got '{l1}'")
  var l2: str = ss.readLine()
  assert(l2 == "", $"line 2: expected '', got '{l2}'")
  var l3: str = ss.readLine()
  assert(l3 == "end", $"line 3: expected 'end', got '{l3}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 50: multiple lines in a single write() must read back as separate lines.
# ==============================================================================
# Regression gate for the recv_buf framing logic. When a peer writes
# "a\nb\nc\n" in one network write(), the receiver's readLine() must
# split it into three lines. A bug that consumes the whole buffer on
# the first readLine (returning "a\nb\nc") or that loses the trailing
# line would break any line-delimited protocol on top of QUIC.

fn test_readline_multiple_lines_in_one_write(): void =>
  print("test_readline_multiple_lines_in_one_write: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Server batches 3 lines into a single write().
  var batch: byte[] = "alpha\nbeta\ngamma\n".toBytes()
  ss.write(batch)

  # Give the batch time to reach the client.
  Time.sleep(200)

  var a: str = cs.readLine()
  assert(a == "alpha", $"line 1: expected 'alpha', got '{a}'")
  var b: str = cs.readLine()
  assert(b == "beta", $"line 2: expected 'beta', got '{b}'")
  var g: str = cs.readLine()
  assert(g == "gamma", $"line 3: expected 'gamma', got '{g}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 51: concurrent read + write on the same stream must not deadlock.
# ==============================================================================
# Regression gate for the stream_mutex / conn_mutex interleaving in the
# read vs write paths. On a bidi stream, read and write use independent
# direction buffers but share locks — a bug where write holds a lock the
# reader needs (or vice versa) would deadlock one of them. Both halves
# must make progress concurrently and complete in bounded time.

fn concurrentStreamWriteBg(stream: QuicStream): int =>
  for var i: int = 0; i < 5; i++ =>
    stream.writeLine($"c-{i}")

  bgDone = true
  return 0

fn test_concurrent_read_write_same_stream(): void =>
  print("test_concurrent_read_write_same_stream: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  # Greeting so server sees the stream.
  cs.writeLine("start")
  var ss: QuicStream = serverConn.acceptStream()
  var start_: str = ss.readLine()
  assert(start_ == "start", $"server: expected 'start', got '{start_}'")

  # Spawn a writer that pushes 5 lines from the client side.
  var h: int = & concurrentStreamWriteBg(cs)

  # Server reads 5 lines and echoes each back as "<line>-echo".
  for var i: int = 0; i < 5; i++ =>
    var line: str = ss.readLine()
    ss.writeLine(line + "-echo")

  # Concurrently with the bg writer, main thread reads the 5 echoes back.
  for var i: int = 0; i < 5; i++ =>
    var echo: str = cs.readLine()
    var expected: str = $"c-{i}-echo"
    assert(echo == expected,
      $"echo {i}: expected '{expected}', got '{echo}'")

  # Wait for the writer bg to finish.
  assert(waitForBg(3000l),
    "concurrent writer did not finish within 3s — possible deadlock")
  h ~

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 52: five concurrent clients on one listener must all round-trip.
# ==============================================================================
# Regression gate for listener-side routing under a small burst of
# simultaneous connections. Each conn has its own per-connection I/O
# thread, its own ngtcp2 state, and its own entry in the listener's
# connection list. A routing bug where incoming packets for conn B
# are delivered to conn A's qconn would break any client after the
# first. Also exercises the accept queue under load.

fn test_many_concurrent_connections(): void =>
  print("test_many_concurrent_connections: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  var clients: QuicConnection[] = {}
  for var i: int = 0; i < 5; i++ =>
    var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
    assert(!c.isClosed(), $"client {i} connect failed")
    clients.push(c)

  var servers: QuicConnection[] = {}
  for var i: int = 0; i < 5; i++ =>
    var s: QuicConnection = server.accept()
    assert(!s.isClosed(), $"server accept {i} returned closed")
    servers.push(s)

  # Each client opens a stream and sends its identifying line.
  var cstreams: QuicStream[] = {}
  for var i: int = 0; i < 5; i++ =>
    var cs: QuicStream = clients[i].openStream()
    cs.writeLine($"ping-{i}")
    cstreams.push(cs)

  # Each server-side conn accepts its stream, reads the line, echoes it.
  var sstreams: QuicStream[] = {}
  for var i: int = 0; i < 5; i++ =>
    var ss: QuicStream = servers[i].acceptStream()
    var msg: str = ss.readLine()
    assert(msg.startsWith("ping-"),
      $"server {i}: expected 'ping-*', got '{msg}'")
    ss.writeLine(msg + "-pong")
    sstreams.push(ss)

  # Each client reads its OWN echo — conns are independent so ordering
  # across clients doesn't matter; each client/conn pair is self-consistent.
  for var i: int = 0; i < 5; i++ =>
    var echo: str = cstreams[i].readLine()
    var expected: str = $"ping-{i}-pong"
    assert(echo == expected,
      $"client {i}: expected '{expected}', got '{echo}'")

  # Tear down.
  for var i: int = 0; i < 5; i++ =>
    cstreams[i].close()
    sstreams[i].close()
    clients[i].close()
    servers[i].close()

  server.close()
  print("PASS\n")

# ==============================================================================
# Test 53: maxBidiStreams=0 on the server must block client opens cleanly.
# ==============================================================================
# Regression gate for the credit-exhausted boundary on the open path.
# When the server advertises initial_max_streams_bidi=0, any client
# openStream() is outside the budget from the first call. The QUIC_CMD
# retry window eventually surrenders and returns a closed stream — must
# not hang forever and must not crash. This is the degenerate case of
# test 28 (stream_budget_exhaustion_is_safe) where the budget is 0 and
# no warm-up opens land inside it.

fn test_config_zero_max_bidi_streams_blocks_opens(): void =>
  print("test_config_zero_max_bidi_streams_blocks_opens: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # Server advertises 0 bidi streams allowed from client.
  var scfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxBidiStreams(0)
  var ccfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, scfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", ccfg)

  # openStream runs into STREAM_ID_BLOCKED immediately. The retry window
  # in QUIC_CMD_OPEN_BIDI is ~2s — bound the call in a bg thread so a
  # hang fails with a clean assertion.
  resetBg()
  var h: int = & pendingOpenStreamBg(client)
  assert(waitForBg(4000l),
    "openStream with 0 budget did not return within 4s")
  assert(bgResultInt == 0,
    "openStream with 0 budget should return a closed stream")
  h ~

  # Connection itself must still be usable for close etc.
  client.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 54: a non-default stream window config must not break a basic round trip.
# ==============================================================================
# Regression gate for setMaxStreamWindow working end-to-end with a value
# smaller than the 256 KB default. The payload here is deliberately
# sized to fit comfortably within the configured window, so this test
# verifies the config propagation + initial transport param wiring
# without depending on MAX_STREAM_DATA delivery timing (which is
# inherently scheduler-dependent on the loopback). A more aggressive
# window-update stress test would need a dedicated harness driving the
# server I/O thread, which is out of scope here.

fn test_config_small_stream_window_roundtrip(): void =>
  print("test_config_small_stream_window_roundtrip: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # 8 KB stream window, well under the 256 KB default but comfortable
  # for our 2 KB payload.
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxStreamWindow(8192)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("start")
  var ss: QuicStream = serverConn.acceptStream()
  var start_: str = ss.readLine()
  assert(start_ == "start", $"expected 'start', got '{start_}'")

  # 2 KB payload — fits inside the 8 KB initial stream window without
  # requiring any MAX_STREAM_DATA updates.
  var payloadStr: str = ""
  for var i: int = 0; i < 128; i++ =>
    payloadStr = payloadStr + "0123456789abcdef"

  var payload: byte[] = payloadStr.toBytes()
  var payloadLen: int = payload.length

  var wrote: int = cs.write(payload)
  assert(wrote == payloadLen,
    $"small-window write returned {wrote}/{payloadLen}")

  cs.close()

  var got: byte[] = ss.readAll()
  assert(got.length == payloadLen,
    $"server received {got.length} bytes, expected {payloadLen}")

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 55: binary payloads containing 0x00 must survive the round trip intact.
# ==============================================================================
# Regression gate for any length-tracking bug that treats the payload as a
# null-terminated C string. write/read are explicitly byte-oriented and
# MUST pass 0x00 through. A regression that runs strlen() on the buffer
# would truncate at the first null and silently corrupt binary RPC payloads.

fn test_binary_payload_with_nulls(): void =>
  print("test_binary_payload_with_nulls: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Three-part payload: "AAAAAAAAAA" + 4 null bytes + "BBBBBBBBBB" = 24 bytes.
  # Build the null bytes via "\x00".toBytes() indexed repeatedly since there's
  # no direct byte literal constructor.
  var part1: byte[] = "AAAAAAAAAA".toBytes()
  var src: byte[] = "\x00".toBytes()
  var zeros: byte[] = {}
  for var i: int = 0; i < 4; i++ =>
    zeros.push(src[0])

  var part2: byte[] = "BBBBBBBBBB".toBytes()

  var w1: int = cs.write(part1)
  assert(w1 == part1.length, $"part1 wrote {w1}/{part1.length}")
  var wz: int = cs.write(zeros)
  assert(wz == zeros.length, $"zeros wrote {wz}/{zeros.length}")
  var w2: int = cs.write(part2)
  assert(w2 == part2.length, $"part2 wrote {w2}/{part2.length}")

  cs.close()

  var got: byte[] = ss.readAll()
  var expected: int = part1.length + zeros.length + part2.length
  assert(got.length == expected,
    $"server received {got.length} bytes, expected {expected}")

  # Verify the nulls are intact at positions 10..13 and letters surround them.
  var zero: byte = src[0]
  var aByte: byte = part1[0]
  var bByte: byte = part2[0]
  for var i: int = 10; i < 14; i++ =>
    assert(got[i] == zero, $"byte {i}: expected null, got non-null")

  assert(got[0] == aByte, "byte 0 should be 'A'")
  assert(got[9] == aByte, "byte 9 should be 'A'")
  assert(got[14] == bByte, "byte 14 should be 'B'")
  assert(got[23] == bByte, "byte 23 should be 'B'")

  ss.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 56: many open streams concurrently live on one connection.
# ==============================================================================
# Regression gate for stream-table growth and per-stream state. Test 42
# exercises sequential open/close churn; this test holds 30 streams OPEN
# at the same time on one connection, proving the SDK maintains many
# concurrently-live streams without stomping on each other's state.
# Each stream does a tiny round trip before cleanup.

fn test_many_streams_on_one_connection(): void =>
  print("test_many_streams_on_one_connection: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxBidiStreams(64)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var count: int = 30
  var cstreams: QuicStream[] = {}
  var sstreams: QuicStream[] = {}

  # Open every stream first (no close until the end).
  for var i: int = 0; i < count; i++ =>
    var cs: QuicStream = client.openStream()
    assert(!cs.isClosed(), $"client open {i} returned closed")
    cs.writeLine($"hi-{i}")
    cstreams.push(cs)

  # Accept each on the server side and echo. Stream-ID order is monotonic
  # within a single connection, so sstreams[i] matches cstreams[i].
  for var i: int = 0; i < count; i++ =>
    var ss: QuicStream = serverConn.acceptStream()
    assert(!ss.isClosed(), $"server accept {i} returned closed")
    var greet: str = ss.readLine()
    assert(greet == $"hi-{i}", $"server {i}: expected 'hi-{i}', got '{greet}'")
    ss.writeLine($"echo-{i}")
    sstreams.push(ss)

  for var i: int = 0; i < count; i++ =>
    var echo: str = cstreams[i].readLine()
    assert(echo == $"echo-{i}",
      $"client {i}: expected 'echo-{i}', got '{echo}'")

  for var i: int = 0; i < count; i++ =>
    cstreams[i].close()
    sstreams[i].close()

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 57: a live conn must stay open across a long-ish idle period below
# the configured idle timeout, then resume work on the next write.
# ==============================================================================
# Regression gate for: idle-timer management with a "mostly quiet with
# occasional bursts" traffic pattern. If ngtcp2's expiry callback
# incorrectly closes the connection despite ongoing application activity
# at the threshold, the conn would die during the quiet period.

fn test_long_idle_then_reuse(): void =>
  print("test_long_idle_then_reuse: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # 2 s idle timeout; idle for 1.2 s between pings (60% of budget).
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(2000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("alive-1")
  var ss: QuicStream = serverConn.acceptStream()
  var m1: str = ss.readLine()
  assert(m1 == "alive-1", $"round 1: expected 'alive-1', got '{m1}'")
  ss.writeLine("ack-1")
  var a1: str = cs.readLine()
  assert(a1 == "ack-1", $"round 1 ack: expected 'ack-1', got '{a1}'")

  Time.sleep(1200)

  assert(!client.isClosed(), "client must stay alive across 1.2s idle")
  assert(!serverConn.isClosed(), "server must stay alive across 1.2s idle")

  cs.writeLine("alive-2")
  var m2: str = ss.readLine()
  assert(m2 == "alive-2", $"round 2: expected 'alive-2', got '{m2}'")
  ss.writeLine("ack-2")
  var a2: str = cs.readLine()
  assert(a2 == "ack-2", $"round 2 ack: expected 'ack-2', got '{a2}'")

  Time.sleep(1200)

  assert(!client.isClosed(), "client must stay alive across 2 idle periods")
  cs.writeLine("alive-3")
  var m3: str = ss.readLine()
  assert(m3 == "alive-3", $"round 3: expected 'alive-3', got '{m3}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 58: two concurrent listener.accept() waiters must each receive a conn.
# ==============================================================================
# Regression gate for accept_cond signalling. Test 19 parks one accept
# then closes; this test parks TWO accepts and then has two clients
# connect. Each waiter must receive one live connection — a regression
# where the cond only wakes one waiter per listener lifetime (instead of
# one per incoming conn) would leave the second waiter wedged.

fn listenerAccept1Bg(listener: QuicListener): int =>
  var c: QuicConnection = listener.accept()
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn listenerAccept2Bg(listener: QuicListener): int =>
  var c: QuicConnection = listener.accept()
  if c.isClosed() =>
    bg2ResultStr = "closed"
  else =>
    bg2ResultStr = "ok"
  bg2Done = true
  return 0

fn test_concurrent_listener_accepts(): void =>
  print("test_concurrent_listener_accepts: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  var ha1: int = & listenerAccept1Bg(server)
  var ha2: int = & listenerAccept2Bg(server)

  Time.sleep(200)

  var c1: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var c2: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)

  var deadline: long = Time.now().millis() + 3000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"concurrent accepts did not both finish within 3s: a1={bgDone} a2={bg2Done}")
    Time.sleep(50)

  assert(bgResultInt == 1, "acceptor 1 should have received a live conn")
  assert(bg2ResultStr == "ok", "acceptor 2 should have received a live conn")
  ha1 ~
  ha2 ~

  c1.close()
  c2.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 59: stream.close() with FIN must preserve unread data for the reader.
# ==============================================================================
# Regression gate for the stream-close FIN path. When the peer writes N
# bytes and then closes the stream (sending FIN), the reader's recv_buf
# still holds those N bytes — they must remain readable AFTER FIN
# arrives, not get dropped by the close-marked-as-done teardown.

fn test_stream_close_preserves_unread_data(): void =>
  print("test_stream_close_preserves_unread_data: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Server writes a fixed payload (no newline) then closes the stream
  # immediately. FIN rides the close. Client has NOT read yet.
  var payload: byte[] = "the-full-fin-payload-exactly".toBytes()
  var payloadLen: int = payload.length
  var wrote: int = ss.write(payload)
  assert(wrote == payloadLen, $"server wrote {wrote}/{payloadLen}")
  ss.close()

  Time.sleep(200)

  # readAll must return ALL the bytes even though FIN has already arrived.
  var got: byte[] = cs.readAll()
  assert(got.length == payloadLen,
    $"client received {got.length} bytes, expected {payloadLen}")

  cs.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 60: stream.write() after stream.close() must be a safe no-op.
# ==============================================================================
# Regression gate for the write path when the stream-level close has
# run but the underlying connection is still alive. Distinct from test
# 10, which closes the entire connection first. A caller that closes a
# stream on error cleanup and then accidentally tries to write again
# must get a safe 0 return, not a crash on stale internal state. The
# connection must remain usable for subsequent streams.

fn test_write_after_stream_close_is_safe(): void =>
  print("test_write_after_stream_close_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("before-close")
  var ss: QuicStream = serverConn.acceptStream()
  var before: str = ss.readLine()
  assert(before == "before-close", $"expected 'before-close', got '{before}'")

  cs.close()

  var data: byte[] = "after-stream-close".toBytes()
  var wrote: int = cs.write(data)
  assert(wrote == 0,
    $"write after stream.close() should return 0, got {wrote}")

  # writeLine is void — must be safe as a no-op.
  cs.writeLine("also-safe")

  # The connection is still alive — a fresh stream on the same conn must
  # succeed and round-trip correctly.
  var cs2: QuicStream = client.openStream()
  assert(!cs2.isClosed(),
    "new stream on same conn should succeed after first stream close")
  cs2.writeLine("new-stream")
  var ss2: QuicStream = serverConn.acceptStream()
  var m: str = ss2.readLine()
  assert(m == "new-stream", $"expected 'new-stream', got '{m}'")

  cs2.close()
  ss2.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 61: periodic application traffic must reset the idle timer.
# ==============================================================================
# Regression gate for idle-timer activity tracking. With a 1 s idle
# timeout and an exchange every 300 ms for ~2.4 s, the timer must be
# reset on every send/recv so the connection stays live. A bug where
# the timer fires on its original schedule regardless of traffic would
# close the conn partway through the loop.

fn test_connection_stays_alive_under_periodic_traffic(): void =>
  print("test_connection_stays_alive_under_periodic_traffic: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  for var i: int = 0; i < 8; i++ =>
    Time.sleep(300)
    assert(!client.isClosed(),
      $"client closed at iteration {i} despite periodic traffic")
    assert(!serverConn.isClosed(),
      $"server closed at iteration {i} despite periodic traffic")
    cs.writeLine($"ping-{i}")
    var m: str = ss.readLine()
    assert(m == $"ping-{i}", $"iter {i}: expected 'ping-{i}', got '{m}'")
    ss.writeLine($"pong-{i}")
    var p: str = cs.readLine()
    assert(p == $"pong-{i}", $"iter {i} pong: expected 'pong-{i}', got '{p}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 62: read(n) must not return more than n bytes.
# ==============================================================================
# Regression gate for the bounded read contract. A caller that passes
# n=32 must get at most 32 bytes back, never the whole recv_buf. This
# matters for protocols that frame fixed-size headers: a regression that
# dumps the whole buffer on the first read would shift the framing.

fn test_read_returns_at_most_max_bytes(): void =>
  print("test_read_returns_at_most_max_bytes: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Server writes a 100-byte payload, then closes (so no more data ever).
  var payload: byte[] = "0123456789abcdefghijABCDEFGHIJklmnopqrstKLMNOPQRST0123456789abcdefghijABCDEFGHIJklmnopqrstKLMNOPQRST".toBytes()
  assert(payload.length == 100,
    $"test setup: payload.length={payload.length}, expected 100")
  ss.write(payload)
  ss.close()

  Time.sleep(200)

  var r1: byte[] = cs.read(32)
  assert(r1.length <= 32,
    $"read(32) returned {r1.length} bytes, must be <= 32")
  assert(r1.length > 0,
    "read(32) returned 0 bytes, expected some data")

  var r2: byte[] = cs.read(32)
  assert(r2.length <= 32,
    $"2nd read(32) returned {r2.length} bytes, must be <= 32")

  var rest: byte[] = cs.readAll()
  var total: int = r1.length + r2.length + rest.length
  assert(total == 100,
    $"total bytes received = {total}, expected 100")

  cs.close()
  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 63: server-initiated stream must be accepted by the client.
# ==============================================================================
# Regression gate for symmetric openStream behavior. All other tests have
# the client opening streams to the server. A server that wants to push
# an unsolicited notification (e.g. "you have new mail") needs to open a
# bidi stream in the reverse direction. Stream direction must be
# symmetric: serverConn.openStream() must work and client.acceptStream()
# must return it.

fn test_server_initiated_stream(): void =>
  print("test_server_initiated_stream: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up with a client-initiated stream so both sides are fully
  # established before we try the reverse direction.
  var warm: QuicStream = client.openStream()
  warm.writeLine("warm")
  var warmSS: QuicStream = serverConn.acceptStream()
  var warmMsg: str = warmSS.readLine()
  assert(warmMsg == "warm", $"warm: expected 'warm', got '{warmMsg}'")

  # Server opens a NEW stream to the client.
  var ss: QuicStream = serverConn.openStream()
  assert(!ss.isClosed(), "serverConn.openStream() returned closed stream")
  ss.writeLine("from-server")

  # Client accepts the server-initiated stream and reads.
  var cs: QuicStream = client.acceptStream()
  assert(!cs.isClosed(), "client.acceptStream() returned closed stream")
  var msg: str = cs.readLine()
  assert(msg == "from-server",
    $"expected 'from-server', got '{msg}'")

  # And the reverse direction on that stream must also work (bidi).
  cs.writeLine("ack-from-client")
  var ack: str = ss.readLine()
  assert(ack == "ack-from-client",
    $"expected 'ack-from-client', got '{ack}'")

  warm.close()
  warmSS.close()
  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 64: rapid graceful connect/disconnect cycles must not leak.
# ==============================================================================
# Regression gate complementing test 15 (abrupt_drop_churn). Test 15
# uses testDropSocket; this exercises the normal graceful-close path
# across many cycles in quick succession to catch cumulative leaks or
# state corruption in the refcount-driven teardown.

fn test_rapid_graceful_connect_disconnect_churn(): void =>
  print("test_rapid_graceful_connect_disconnect_churn: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  var startMs: long = Time.now().millis()
  for var i: int = 0; i < 10; i++ =>
    var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
    assert(!c.isClosed(), $"cycle {i}: connect failed")
    var s: QuicConnection = server.accept()
    assert(!s.isClosed(), $"cycle {i}: accept returned closed")

    var cs: QuicStream = c.openStream()
    cs.writeLine($"cycle-{i}")
    var ss: QuicStream = s.acceptStream()
    var m: str = ss.readLine()
    assert(m == $"cycle-{i}", $"cycle {i}: expected 'cycle-{i}', got '{m}'")

    cs.close()
    ss.close()
    c.close()
    s.close()

  var elapsedMs: long = Time.now().millis() - startMs
  assert(elapsedMs < 10000l,
    $"10 graceful churn cycles took {elapsedMs}ms, expected < 10000ms")

  server.close()
  print("PASS\n")

# ==============================================================================
# Test 65: 100 tiny writeLine calls must all arrive in order on the peer.
# ==============================================================================
# Regression gate for the WRITE_MORE coalescing path and cmd-queue
# serialisation. 100 back-to-back tiny lines stress the ngtcp2 write
# pacing + the SDK's write_bufs list. A regression that loses a write
# to the cmd queue (e.g. an overflow) or that reorders writes would
# surface here as a missing or out-of-order line.

fn test_many_tiny_writes_coalesce(): void =>
  print("test_many_tiny_writes_coalesce: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Client fires 100 tiny lines as fast as possible.
  for var i: int = 0; i < 100; i++ =>
    cs.writeLine($"t-{i}")

  cs.close()

  # Server reads them back in order.
  for var i: int = 0; i < 100; i++ =>
    var m: str = ss.readLine()
    assert(m == $"t-{i}", $"line {i}: expected 't-{i}', got '{m}'")

  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 66: two concurrent close() calls on the same connection must be safe.
# ==============================================================================
# Regression gate for close-path thread safety. A caller with two threads
# that both detect an error condition at the same time and both call
# client.close() must not double-free the internal state. The refcount
# dispose path has to absorb concurrent invocations, not just sequential
# ones (which test 30 already covers).

fn closeConn1Bg(conn: QuicConnection): int =>
  conn.close()
  bgDone = true
  return 0

fn closeConn2Bg(conn: QuicConnection): int =>
  conn.close()
  bg2Done = true
  return 0

fn test_concurrent_close_same_conn(): void =>
  print("test_concurrent_close_same_conn: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up so the conn is fully live before we close it.
  var cs: QuicStream = client.openStream()
  cs.writeLine("warm")
  var ss: QuicStream = serverConn.acceptStream()
  var warm: str = ss.readLine()
  assert(warm == "warm", $"expected 'warm', got '{warm}'")
  cs.close()
  ss.close()

  # Two threads race to close the same client conn.
  var h1: int = & closeConn1Bg(client)
  var h2: int = & closeConn2Bg(client)

  var deadline: long = Time.now().millis() + 3000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"concurrent close did not finish within 3s: t1={bgDone} t2={bg2Done}")
    Time.sleep(50)
  h1 ~
  h2 ~

  assert(client.isClosed(),
    "client must report closed after concurrent close() calls")

  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 67: two concurrent connects must both succeed against one listener.
# ==============================================================================
# Regression gate for listener's ability to handle overlapping handshakes.
# Test 52 does 5 sequential connects; this test does 2 threaded concurrent
# connects so their initial CRYPTO frames and handshakes interleave on
# the listener's UDP socket. A routing/state bug in the multiplex path
# would cause one or both to fail.

fn concurrentConnect1Bg(port: int): int =>
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  if c.isClosed() =>
    bgResultInt = 0
  else =>
    bgResultInt = 1
  bgDone = true
  return 0

fn concurrentConnect2Bg(port: int): int =>
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  if c.isClosed() =>
    bg2ResultStr = "closed"
  else =>
    bg2ResultStr = "ok"
  bg2Done = true
  return 0

fn test_listener_concurrent_connect_burst(): void =>
  print("test_listener_concurrent_connect_burst: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  # Fire both connects concurrently.
  var h1: int = & concurrentConnect1Bg(port)
  var h2: int = & concurrentConnect2Bg(port)

  # Accept both on the main thread. Listener must deliver both.
  var s1: QuicConnection = server.accept()
  assert(!s1.isClosed(), "accept 1 returned closed conn")
  var s2: QuicConnection = server.accept()
  assert(!s2.isClosed(), "accept 2 returned closed conn")

  var deadline: long = Time.now().millis() + 3000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"concurrent connects did not finish within 3s: t1={bgDone} t2={bg2Done}")
    Time.sleep(50)

  assert(bgResultInt == 1,
    "first concurrent connect did not report alive")
  assert(bg2ResultStr == "ok",
    "second concurrent connect did not report alive")
  h1 ~
  h2 ~

  s1.close()
  s2.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 68: writeLine with an embedded newline produces two lines on the peer.
# ==============================================================================
# Documents the writeLine semantic: it concatenates the input text with a
# trailing '\n' and writes the raw bytes. If the input itself contains
# '\n', the peer's readLine will split the combined stream on every '\n',
# observing two separate lines. This is a usability footgun — API
# reviewers may want to escape or reject embedded newlines — but the
# current behavior is what it is and we lock it down so a future change
# is intentional, not accidental.

fn test_writeline_with_embedded_newline(): void =>
  print("test_writeline_with_embedded_newline: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  # Embedded newline in the middle of the payload.
  cs.writeLine("part-a\npart-b")

  # Peer sees two lines.
  var l1: str = ss.readLine()
  assert(l1 == "part-a", $"line 1: expected 'part-a', got '{l1}'")
  var l2: str = ss.readLine()
  assert(l2 == "part-b", $"line 2: expected 'part-b', got '{l2}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 69: many sequential unidirectional streams must all deliver cleanly.
# ==============================================================================
# Regression gate for the unidirectional stream lifecycle across many
# opens. Test 25 covers a single uni stream + abrupt drop; this test
# opens/writes/closes 10 uni streams back-to-back and verifies every
# payload is delivered on the server side. Exercises the uni-stream
# ID space and acceptStream's handling of uni arrivals.

fn test_many_uni_streams_sequential(): void =>
  print("test_many_uni_streams_sequential: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxUniStreams(32)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var count: int = 10

  # Open every stream on the client side, send one line, close.
  for var i: int = 0; i < count; i++ =>
    var cs: QuicStream = client.openUnidirectionalStream()
    assert(!cs.isClosed(),
      $"client uni open {i} returned closed")
    assert(cs.isUnidirectional(),
      $"stream {i} should report unidirectional")
    cs.writeLine($"uni-{i}")
    cs.close()

  # Drain all 10 on the server. A uni stream that arrived with data+FIN
  # in one packet may report isClosed=true here — the peer side is done.
  # The point of the test is that the payload is still readable.
  for var i: int = 0; i < count; i++ =>
    var ss: QuicStream = serverConn.acceptStream()
    var m: str = ss.readLine()
    assert(m == $"uni-{i}",
      $"server uni {i}: expected 'uni-{i}', got '{m}'")
    ss.close()

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 70: connect() with a hostname (not a literal IP) must resolve.
# ==============================================================================
# Regression gate for the DNS resolution path inside quic_connection_create.
# "localhost" exercises getaddrinfo with a real hostname rather than
# parsing an IPv4 literal, which is what any real-world caller will use.
# If the SDK accidentally only parses IPv4 literals in-line, this test
# fails loudly.

fn test_connect_with_localhost_hostname(): void =>
  print("test_connect_with_localhost_hostname: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  # Connect via hostname rather than IP literal. getaddrinfo must resolve
  # "localhost" → 127.0.0.1 (or ::1 with AF_INET forcing IPv4 only).
  var client: QuicConnection = QuicConnection.connectWith($"localhost:{port}", cfg)
  assert(!client.isClosed(),
    "connect('localhost:...') failed — hostname resolution broken?")

  var serverConn: QuicConnection = server.accept()
  assert(!serverConn.isClosed(), "server accept returned closed")

  var cs: QuicStream = client.openStream()
  cs.writeLine("hostname-ok")
  var ss: QuicStream = serverConn.acceptStream()
  var m: str = ss.readLine()
  assert(m == "hostname-ok",
    $"expected 'hostname-ok', got '{m}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 71: server-initiated unidirectional stream must reach the client.
# ==============================================================================
# Regression gate for the reverse of the fix in test 69: a server opens a
# uni stream to the client and writes data. The client must accept it
# and read the payload. Exercises the server uni stream ID space (IDs
# 3, 7, 11, ...) and the client-side acceptStream + uni recv path.

fn test_server_initiated_uni_stream(): void =>
  print("test_server_initiated_uni_stream: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up with a client bidi stream so both sides are fully established.
  var warm: QuicStream = client.openStream()
  warm.writeLine("warm")
  var warmSS: QuicStream = serverConn.acceptStream()
  var warmMsg: str = warmSS.readLine()
  assert(warmMsg == "warm", $"warm: expected 'warm', got '{warmMsg}'")

  # Server opens a UNI stream to the client. stream.writeLine sends the
  # payload, close() sends FIN.
  var ss: QuicStream = serverConn.openUnidirectionalStream()
  assert(!ss.isClosed(), "serverConn.openUnidirectionalStream() returned closed")
  ss.writeLine("from-server-uni")
  ss.close()

  # Client accepts the server-initiated uni stream. A uni stream arriving
  # with data + FIN in one packet may already report isClosed=true — the
  # point is the payload is still readable.
  var cs: QuicStream = client.acceptStream()
  var msg: str = cs.readLine()
  assert(msg == "from-server-uni",
    $"expected 'from-server-uni', got '{msg}'")

  warm.close()
  warmSS.close()
  cs.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 72: multiple writes on one uni stream before close must all be delivered.
# ==============================================================================
# Regression gate for the multi-write path on uni streams. Test 69 sends
# one line per uni stream; this test sends FIVE lines on a single uni
# stream before closing. The reader must observe all five in order via
# readLine() calls. Exercises recv_buf accumulation across multiple
# recv_stream_data_cb calls on a single stream.

fn test_uni_stream_multiple_writes_before_close(): void =>
  print("test_uni_stream_multiple_writes_before_close: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openUnidirectionalStream()
  for var i: int = 0; i < 5; i++ =>
    cs.writeLine($"part-{i}")

  cs.close()

  var ss: QuicStream = serverConn.acceptStream()
  for var i: int = 0; i < 5; i++ =>
    var m: str = ss.readLine()
    assert(m == $"part-{i}",
      $"part {i}: expected 'part-{i}', got '{m}'")

  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 73: a stream opened + closed with no data must be skipped by accept.
# ==============================================================================
# Regression gate for the skip-on-empty-closed branch in accept_stream.
# When the peer opens a stream and closes it without writing, the
# resulting empty+closed stream must be silently dropped so the caller
# doesn't get an immediate-EOF that looks like connection death. Then
# when a real stream with data arrives, that one must come through.

fn test_zero_data_stream_skipped_by_accept(): void =>
  print("test_zero_data_stream_skipped_by_accept: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Client opens stream A and immediately closes without writing.
  var empty: QuicStream = client.openStream()
  empty.close()

  # Give the empty stream time to fully land on the server (open+FIN).
  Time.sleep(100)

  # Client opens stream B with a real payload.
  var real: QuicStream = client.openStream()
  real.writeLine("real-data")

  # Server accepts. With the skip-empty-closed path working, the FIRST
  # stream the user sees should be the one carrying the real data.
  var ss: QuicStream = serverConn.acceptStream()
  var m: str = ss.readLine()
  assert(m == "real-data",
    $"expected the real-data stream, got '{m}'")

  real.close()
  empty.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 74: both sides call openStream at the same time — both must work.
# ==============================================================================
# Regression gate for simultaneous stream creation from both ends of one
# connection. Stream ID spaces are disjoint (client=0,4,..., server=1,5,...)
# so there's no ID collision, but a bug in the open-path mutex could
# still deadlock or corrupt ci->streams[] if both sides call openStream
# concurrently.

fn clientOpenBg(conn: QuicConnection): int =>
  var s: QuicStream = conn.openStream()
  if s.isClosed() =>
    bgResultInt = 0
  else =>
    bgResultInt = 1
    s.writeLine("client-opened")
    s.close()
  bgDone = true
  return 0

fn serverOpenBg(conn: QuicConnection): int =>
  var s: QuicStream = conn.openStream()
  if s.isClosed() =>
    bg2ResultStr = "closed"
  else =>
    bg2ResultStr = "ok"
    s.writeLine("server-opened")
    s.close()
  bg2Done = true
  return 0

fn test_bidi_open_simultaneously_both_ends(): void =>
  print("test_bidi_open_simultaneously_both_ends: ")
  resetBg()

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up so handshake is fully done before the race.
  var warm: QuicStream = client.openStream()
  warm.writeLine("warm")
  var warmSS: QuicStream = serverConn.acceptStream()
  var warmMsg: str = warmSS.readLine()
  assert(warmMsg == "warm", $"warm: expected 'warm', got '{warmMsg}'")
  warm.close()
  warmSS.close()

  # Both sides call openStream at the same moment. Both must succeed.
  var h1: int = & clientOpenBg(client)
  var h2: int = & serverOpenBg(serverConn)

  var deadline: long = Time.now().millis() + 3000l
  while !bgDone || !bg2Done =>
    if Time.now().millis() >= deadline =>
      assert(false,
        $"simultaneous opens did not both finish within 3s: c={bgDone} s={bg2Done}")
    Time.sleep(50)

  assert(bgResultInt == 1, "client openStream did not return alive")
  assert(bg2ResultStr == "ok", "server openStream did not return alive")
  h1 ~
  h2 ~

  # Drain the streams so neither side hangs during teardown.
  var srvRecv: QuicStream = serverConn.acceptStream()
  var cm: str = srvRecv.readLine()
  assert(cm == "client-opened",
    $"server should see 'client-opened', got '{cm}'")
  srvRecv.close()

  var cliRecv: QuicStream = client.acceptStream()
  var sm: str = cliRecv.readLine()
  assert(sm == "server-opened",
    $"client should see 'server-opened', got '{sm}'")
  cliRecv.close()

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 75: openStream + write immediately after connect must not race.
# ==============================================================================
# Regression gate for any lurking "wait for handshake" gap between
# connectWith returning and the first stream operation working. Per the
# SDK contract connectWith blocks until handshake completes (or fails
# bounded), so a subsequent openStream + writeLine pair must be usable
# with no additional delay.

fn test_write_immediately_after_connect(): void =>
  print("test_write_immediately_after_connect: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(5000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()

  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  # NO sleep between connect and openStream. First op must just work.
  var cs: QuicStream = client.openStream()
  assert(!cs.isClosed(),
    "openStream immediately after connect returned closed")
  cs.writeLine("first-op")

  var serverConn: QuicConnection = server.accept()
  var ss: QuicStream = serverConn.acceptStream()
  var m: str = ss.readLine()
  assert(m == "first-op",
    $"expected 'first-op', got '{m}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 76: long-running connection with 3 bursts and idle gaps.
# ==============================================================================
# Regression gate for mixed steady-state: a conn that serves periodic
# bursts separated by idle periods is the most common real-world pattern.
# Validates that traffic burst → idle → next burst all work without the
# idle timer firing between bursts. Uses 2s idle timeout with 1s idle gaps.

fn test_long_running_with_bursts(): void =>
  print("test_long_running_with_bursts: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(2000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # One long-lived stream for all 3 bursts.
  var cs: QuicStream = client.openStream()
  cs.writeLine("open")
  var ss: QuicStream = serverConn.acceptStream()
  var open_: str = ss.readLine()
  assert(open_ == "open", $"expected 'open', got '{open_}'")

  for var burst: int = 0; burst < 3; burst++ =>
    for var i: int = 0; i < 5; i++ =>
      cs.writeLine($"b{burst}-m{i}")
      var m: str = ss.readLine()
      assert(m == $"b{burst}-m{i}",
        $"burst {burst} msg {i}: expected 'b{burst}-m{i}', got '{m}'")

    # Idle gap between bursts — must stay under the 2s idle timeout.
    Time.sleep(1000)
    assert(!client.isClosed(),
      $"client closed during idle gap after burst {burst}")
    assert(!serverConn.isClosed(),
      $"server closed during idle gap after burst {burst}")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 77: 30 back-to-back small RPCs on one long-lived stream.
# ==============================================================================
# Regression gate for the "persistent RPC client" pattern: one conn,
# one stream, many request/response pairs. Different from
# test_persistent_rpc_burst in tests/net/test_quic.sn which opens a
# new stream per iteration. This test keeps ONE stream open for the
# whole loop to exercise steady-state recv_buf management and readLine
# framing across many small exchanges.

fn test_many_small_rpcs_serialized(): void =>
  print("test_many_small_rpcs_serialized: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("hello")
  var ss: QuicStream = serverConn.acceptStream()
  var hello: str = ss.readLine()
  assert(hello == "hello", $"expected 'hello', got '{hello}'")

  # 30 request/response pairs on the same stream.
  for var i: int = 0; i < 30; i++ =>
    cs.writeLine($"req-{i}")
    var req: str = ss.readLine()
    assert(req == $"req-{i}",
      $"req {i}: expected 'req-{i}', got '{req}'")
    ss.writeLine($"resp-{i}")
    var resp: str = cs.readLine()
    assert(resp == $"resp-{i}",
      $"resp {i}: expected 'resp-{i}', got '{resp}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 78: 10 server-initiated uni streams reach the client in order.
# ==============================================================================
# Regression gate for the batch-server-uni path: 10 uni streams opened
# on the server, each carrying one line, all received and readable on
# the client side. Exercises the SERVER side of the same lifecycle fix
# that test 69 exercises on the client.

fn test_many_uni_from_server_to_client(): void =>
  print("test_many_uni_from_server_to_client: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxUniStreams(32)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Warm up a client bidi so handshake is settled.
  var warm: QuicStream = client.openStream()
  warm.writeLine("warm")
  var warmSS: QuicStream = serverConn.acceptStream()
  var warmMsg: str = warmSS.readLine()
  assert(warmMsg == "warm", $"expected 'warm', got '{warmMsg}'")
  warm.close()
  warmSS.close()

  # Server opens 10 uni streams, sends one line each, closes each.
  for var i: int = 0; i < 10; i++ =>
    var ss: QuicStream = serverConn.openUnidirectionalStream()
    assert(!ss.isClosed(), $"server uni open {i} returned closed")
    ss.writeLine($"srv-uni-{i}")
    ss.close()

  # Client drains all 10 in order.
  for var i: int = 0; i < 10; i++ =>
    var cs: QuicStream = client.acceptStream()
    var m: str = cs.readLine()
    assert(m == $"srv-uni-{i}",
      $"client uni {i}: expected 'srv-uni-{i}', got '{m}'")
    cs.close()

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 79: bidi and uni streams interleaved on one connection.
# ==============================================================================
# Regression gate for mixed stream types on one conn. Opens alternate
# bidi and uni streams and verifies each arrives on the other side.
# Exercises the accept queue's ability to interleave different stream
# types without confusion.

fn test_mixed_bidi_and_uni_on_one_conn(): void =>
  print("test_mixed_bidi_and_uni_on_one_conn: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxUniStreams(32)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Open a bidi, a uni, a bidi, a uni — 4 streams total.
  var b1: QuicStream = client.openStream()
  b1.writeLine("bidi-1")
  var u1: QuicStream = client.openUnidirectionalStream()
  u1.writeLine("uni-1")
  u1.close()
  var b2: QuicStream = client.openStream()
  b2.writeLine("bidi-2")
  var u2: QuicStream = client.openUnidirectionalStream()
  u2.writeLine("uni-2")
  u2.close()

  # Server drains all 4. Collect the messages into a set-ish structure
  # because stream arrival order across types is not guaranteed.
  var count: int = 0
  var seenBidi1: bool = false
  var seenBidi2: bool = false
  var seenUni1: bool = false
  var seenUni2: bool = false

  for var i: int = 0; i < 4; i++ =>
    var ss: QuicStream = serverConn.acceptStream()
    var m: str = ss.readLine()
    if m == "bidi-1" =>
      seenBidi1 = true
    if m == "bidi-2" =>
      seenBidi2 = true
    if m == "uni-1" =>
      seenUni1 = true
    if m == "uni-2" =>
      seenUni2 = true
    ss.close()
    count++

  assert(count == 4, $"server should accept 4 streams, got {count}")
  assert(seenBidi1, "server did not see bidi-1")
  assert(seenBidi2, "server did not see bidi-2")
  assert(seenUni1, "server did not see uni-1")
  assert(seenUni2, "server did not see uni-2")

  b1.close()
  b2.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 80: streams arrive at acceptStream in their open order.
# ==============================================================================
# Regression gate for FIFO ordering of the accept queue. Within a single
# stream type, streams are opened by the peer with monotonically
# increasing IDs and must be delivered by acceptStream in that same
# order. A bug in the queue management (e.g. using the wrong head/tail
# index) would shuffle them.

fn test_accept_order_matches_open_order(): void =>
  print("test_accept_order_matches_open_order: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var count: int = 15
  var openedIds: long[] = {}
  for var i: int = 0; i < count; i++ =>
    var cs: QuicStream = client.openStream()
    cs.writeLine($"id-check-{i}")
    openedIds.push(cs.id())
    cs.close()

  var acceptedIds: long[] = {}
  for var i: int = 0; i < count; i++ =>
    var ss: QuicStream = serverConn.acceptStream()
    var m: str = ss.readLine()
    assert(m == $"id-check-{i}",
      $"stream {i}: expected 'id-check-{i}', got '{m}'")
    acceptedIds.push(ss.id())
    ss.close()

  # The accepted stream IDs must be exactly the same (and in the same
  # order) as the opened IDs.
  for var i: int = 0; i < count; i++ =>
    assert(openedIds[i] == acceptedIds[i],
      $"stream {i}: opened id={openedIds[i]}, accepted id={acceptedIds[i]}")

  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Main
# ==============================================================================

fn main(): void =>
  print("=== SDK QUIC Resilience Tests ===

")

  test_uni_stream_abrupt_drop_is_safe()
  test_stream_budget_exhaustion_is_safe()
  test_write_large_payload_streams_through()
  test_readline_multiple_lines_in_one_write()
  test_binary_payload_with_nulls()
  test_server_initiated_stream()
  test_many_uni_streams_sequential()
  test_server_initiated_uni_stream()
  test_zero_data_stream_skipped_by_accept()
  test_accept_order_matches_open_order()

  print("
All QUIC resilience tests passed!
")
