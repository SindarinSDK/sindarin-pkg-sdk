# ==============================================================================
# test_quic_resilience.sn - Failure-mode tests for QUIC
# ==============================================================================
# These tests describe the REQUIRED resilience behavior of the QUIC stack:
#
# (a) Connect must fail in bounded time when the peer is not ready,
# so one-shot callers don't wedge on startup/readiness races.
# (b) Idle timeout must mark the connection closed in bounded time.
# (c) Pending readLine() / acceptStream() / write() on a connection must
# unblock and surface a clean signal when the peer closes — never
# hang on a lost condition-variable wakeup.
# (d) Post-close operations must not crash, and repeated close must be
# idempotent.
#
# Every test has a wall-clock deadline. Background operations run in spawned
# threads and communicate with main via `sync var` flags; main polls those
# flags until a deadline, then asserts. A regression therefore fails loudly
# within seconds instead of hanging the runner until its 30s wall timeout.
#
# Some of these tests describe behavior that is NOT currently correct on main.
# Those tests are the regression gate for the upcoming fixes. The comment on
# each test says what it catches.
# ==============================================================================

import "sindarin-pkg-sdk/src/net/quic"
import "sindarin-pkg-sdk/src/net/tcp"
import "sindarin-pkg-sdk/src/time/time"

# ==============================================================================
# Shared state for background threads
# ==============================================================================
# Reused across tests via resetBg() — tests run sequentially so there is no
# cross-test contention.

sync var bgDone: bool = false
sync var bgElapsedMs: long = 0l
sync var bgResultInt: int = 0
sync var bgResultStr: str = ""

# Second set of flags for tests that need two concurrent background threads
sync var bg2Done: bool = false
sync var bg2ResultStr: str = ""

fn resetBg(): void =>
  bgDone = false
  bgElapsedMs = 0l
  bgResultInt = 0
  bgResultStr = ""
  bg2Done = false
  bg2ResultStr = ""

# Poll `bgDone` at 50ms intervals until it flips or `timeoutMs` elapses.
# Returns true if the flag flipped, false on deadline.
fn waitForBg(timeoutMs: long): bool =>
  var deadline: long = Time.now().millis() + timeoutMs
  while !bgDone =>
    if Time.now().millis() >= deadline =>
      return false
    Time.sleep(50)
  return true

# ==============================================================================
# Test 1: connect() to a port with no listener must return in bounded time.
# ==============================================================================
# Regression gate for: one-shot callers that start before a sibling service is
# ready must not block for 30 seconds on the default idle timeout. We force a
# short idle timeout via config and assert the call returns within 5 seconds.
#
# Passes on main IF ngtcp2's idle timer is honoured as a handshake bound.
# Fails if the handshake wait is unbounded, or if connect() deadlocks on the
# closed-path condition broadcast.

fn connectNoListenerBg(port: int): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(2000)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgDone = true
  return 0

fn pendingOpenStreamBg(conn: QuicConnection): int =>
  var s: QuicStream = conn.openStream()
  bgResultInt = 1
  if s.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn connectToTcpBg(port: int): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(800)
  var c: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn connectMalformedBg(addr: str): int =>
  var start: Time = Time.now()
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(1000)
  var c: QuicConnection = QuicConnection.connectWith(addr, cfg)
  bgElapsedMs = Time.now().diff(start)
  bgResultInt = 1
  if c.isClosed() =>
    bgResultInt = 0
  bgDone = true
  return 0

fn test_write_after_close_is_safe(): void =>
  print("test_write_after_close_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)
  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var clientStream: QuicStream = client.openStream()
  clientStream.writeLine("first")
  var serverStream: QuicStream = serverConn.acceptStream()
  var first: str = serverStream.readLine()
  assert(first == "first", $"server should see 'first', got '{first}'")

  # Close the client; subsequent writes on the stream must be a no-op.
  client.close()
  Time.sleep(100)

  var payload: byte[] = "after-close".toBytes()
  var wrote: int = clientStream.write(payload)
  assert(wrote == 0,
    $"write() after close should return 0, got {wrote}")

  serverStream.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 11: reconnect after peer close on the same listener.
# ==============================================================================
# Regression gate for long-lived callers: when the server gracefully closes a
# connection, the client must be able to open a fresh connection to the SAME
# listener and resume work. This is the pattern any "reconnecting RPC client"
# must use because the SDK does not yet offer connectWithRetry or an explicit
# reconnect(). It also exercises listener.accept() across multiple connection
# lifetimes, which the old global-registry lifecycle was known to mishandle.

fn test_openstream_after_abrupt_drop_is_safe(): void =>
  print("test_openstream_after_abrupt_drop_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(600)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  # Confirm live before we drop.
  var warmup: QuicStream = client.openStream()
  warmup.writeLine("warmup")
  var wss: QuicStream = serverConn.acceptStream()
  var warm: str = wss.readLine()
  assert(warm == "warmup", $"server should see 'warmup', got '{warm}'")
  warmup.close()
  wss.close()

  # Abrupt drop and wait for client to notice.
  serverConn.quicTestDropSocket()
  var deadline: long = Time.now().millis() + 2500l
  while !client.isClosed() =>
    if Time.now().millis() >= deadline =>
      assert(false, "client did not observe abrupt drop within 2.5s")
    Time.sleep(50)

  # Now attempt openStream on the dead connection. Must not crash.
  # Must return a stream whose isClosed() is true.
  var deadStream: QuicStream = client.openStream()
  assert(deadStream.isClosed(),
    "openStream on a dead connection must return an already-closed stream")

  # write() on the dead stream must also be a safe no-op.
  var data: byte[] = "post-drop".toBytes()
  var wrote: int = deadStream.write(data)
  assert(wrote == 0,
    $"write() on dead stream must return 0, got {wrote}")

  serverConn.close()
  server.close()
  client.close()
  print("PASS\n")

# ==============================================================================
# Test 15: abrupt-drop churn — 10 cycles must not leak or corrupt state.
# ==============================================================================
# Cumulative regression gate for the cleanup path on the abrupt-failure branch.
# Exercises the full (bind, connect, exchange, abrupt-drop, wait-for-close,
# dispose) sequence many times in a row on the same listener to surface
# cumulative memory/state leaks or mutex/fd corruption across cycles.

fn test_bind_missing_cert_file_fails_clean(): void =>
  print("test_bind_missing_cert_file_fails_clean: ")

  var listener: QuicListener = QuicListener.bind(
    ":0",
    "tests/net/does_not_exist_cert.pem",
    "tests/net/does_not_exist_key.pem")

  # C side returns NULL → Sindarin receives a null ref. port() / close()
  # must handle that without dereferencing.
  var p: int = listener.port()
  assert(p == 0, $"bind with missing cert should report port=0, got {p}")
  listener.close()
  listener.close()
  print("PASS\n")

# ==============================================================================
# Test 33: bind with a malformed address must fail clean, not crash.
# ==============================================================================
# Regression gate for parse_address on the bind path. Garbage in the
# address string must fail before any socket/SSL state is allocated and
# return a null handle.

fn test_bind_with_malformed_address_fails_clean(): void =>
  print("test_bind_with_malformed_address_fails_clean: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  # Use inputs that fail at parse_address (the IPv6 "[host]" syntax
  # with no closing bracket), so the failure is synchronous and does
  # not depend on getaddrinfo timing — which is slow on macOS when
  # DNS resolvers spend seconds trying real-looking hostnames.
  var l1: QuicListener = QuicListener.bind("[", cert_path, key_path)
  assert(l1.port() == 0, "bind('[') should report port=0")
  l1.close()

  var l2: QuicListener = QuicListener.bind("[broken", cert_path, key_path)
  assert(l2.port() == 0, "bind('[broken') should report port=0")
  l2.close()
  print("PASS\n")

# ==============================================================================
# Test 34: bind(":0") must report a real, non-zero port.
# ==============================================================================
# Regression gate for the ephemeral port readback path (getsockname after
# bind). Callers that later advertise the listener's port to peers depend
# on this invariant — a zero return would be silently indistinguishable
# from a failed bind.

fn test_connect_to_tcp_listener_is_bounded(): void =>
  print("test_connect_to_tcp_listener_is_bounded: ")
  resetBg()

  # Stand up a TCP listener on an ephemeral port. The QUIC client will try
  # to handshake at that port; no UDP socket is bound there, so the
  # handshake must fail via the idle timer (or kernel ECONNREFUSED on the
  # connected UDP socket).
  var tcp: TcpListener = TcpListener.bind(":0")
  var port: int = tcp.port()

  var h: int = & connectToTcpBg(port)

  assert(waitForBg(3000l),
    "connect() to TCP port did not return within 3s (idleTimeout=800ms)")
  assert(bgElapsedMs <= 2500l,
    $"connect() to TCP port took {bgElapsedMs}ms, expected <= 2500ms")
  assert(bgResultInt == 0,
    "connect() to TCP port should return a closed handle")
  h ~
  tcp.dispose()
  print("PASS\n")

# ==============================================================================
# Test 36: connect() to an unreachable IP must bound.
# ==============================================================================
# Regression gate for the "no route / ICMP unreachable / black hole" failure
# class. 192.0.2.1 is TEST-NET-1 (RFC 5737), reserved for documentation and
# guaranteed never to route to a real host. A connect() against it must
# bound via the handshake/idle timer — long-lived callers must not wedge
# indefinitely on a misrouted address.

fn test_connect_with_malformed_address(): void =>
  print("test_connect_with_malformed_address: ")
  resetBg()

  # Non-numeric port: parse_address must reject.
  var h: int = & connectMalformedBg("127.0.0.1:abc")
  assert(waitForBg(3000l),
    "connect(malformed) did not return within 3s")
  assert(bgResultInt == 0,
    "connect(malformed) should return a closed handle")
  h ~

  resetBg()
  # Empty string: must also bound and not crash.
  var h2: int = & connectMalformedBg("")
  assert(waitForBg(3000l),
    "connect('') did not return within 3s")
  assert(bgResultInt == 0,
    "connect('') should return a closed handle")
  h2 ~
  print("PASS\n")

# ==============================================================================
# Test 38: migrate() on a closed connection must be a safe no-op.
# ==============================================================================
# Regression gate for post-close API safety of the migrate path. migrate()
# checks ci->closed before touching the ngtcp2 state machine, but a
# regression that bypasses that check (or dereferences ci after close)
# would crash the process on a harmless-looking logging call.

fn test_migrate_on_closed_conn_is_safe(): void =>
  print("test_migrate_on_closed_conn_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  client.close()
  Time.sleep(100)

  # Migrate on a closed client — must be a no-op, not a crash.
  client.migrate("127.0.0.1:0")
  client.migrate("127.0.0.1:0")

  # Migrate with a malformed address on a closed conn — also safe.
  client.migrate("not_a_host:abc")

  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 39: resumptionToken() on a closed connection must be safe.
# ==============================================================================
# Regression gate for: logging/telemetry callers that grab a resumption
# token off a connection they're about to drop. Must return a valid
# byte[] (possibly empty), never crash on a null ci.

fn test_write_empty_bytes_is_safe(): void =>
  print("test_write_empty_bytes_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  var cfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(0)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, cfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", cfg)
  var serverConn: QuicConnection = server.accept()

  var cs: QuicStream = client.openStream()
  cs.writeLine("ping")
  var ss: QuicStream = serverConn.acceptStream()
  var ping: str = ss.readLine()
  assert(ping == "ping", $"expected 'ping', got '{ping}'")

  # Empty write must return a valid count (conventionally 0) and must
  # not disturb the stream.
  var empty: byte[] = {}
  var wrote: int = cs.write(empty)
  assert(wrote == 0,
    $"write(empty) should return 0, got {wrote}")

  # Subsequent normal write must still work.
  cs.writeLine("after-empty")
  var after: str = ss.readLine()
  assert(after == "after-empty", $"expected 'after-empty', got '{after}'")

  cs.close()
  ss.close()
  client.close()
  serverConn.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 48: read(0) must return an empty buffer promptly.
# ==============================================================================
# Regression gate for the read(0) fast path. A caller that passes 0 for
# maxBytes (e.g. as a result of arithmetic producing 0) must not block
# forever waiting for a byte that will never be requested. Return must be
# an empty byte[] within milliseconds.

fn test_double_close_is_safe(): void =>
  print("test_double_close_is_safe: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"

  var server: QuicListener = QuicListener.bind(":0", cert_path, key_path)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connect($"127.0.0.1:{port}")
  var serverConn: QuicConnection = server.accept()

  client.close()
  client.close() # must not crash

  serverConn.close()
  serverConn.close() # must not crash

  server.close()
  server.close() # must not crash

  print("PASS\n")

# ==============================================================================
# Test 31: listener.accept() AFTER listener.close() must return bounded.
# ==============================================================================
# Regression gate for the close-then-accept ordering on the listener's
# accept_cond. Test 19 covers accept-then-close (parked acceptor wakes); this
# covers the reverse: the listener is already closed when a caller invokes
# accept(). The while-loop guard must see !running and exit immediately
# without ever parking on the cond, otherwise callers shutting down get
# stuck on the condvar.

fn test_config_zero_max_bidi_streams_blocks_opens(): void =>
  print("test_config_zero_max_bidi_streams_blocks_opens: ")

  var cert_path: str = "tests/net/test_quic_cert.pem"
  var key_path: str = "tests/net/test_quic_key.pem"
  # Server advertises 0 bidi streams allowed from client.
  var scfg: QuicConfig = QuicConfig.defaults()
    .setIdleTimeout(10000)
    .setMaxBidiStreams(0)
  var ccfg: QuicConfig = QuicConfig.defaults().setIdleTimeout(10000)

  var server: QuicListener = QuicListener.bindWith(":0", cert_path, key_path, scfg)
  var port: int = server.port()
  var client: QuicConnection = QuicConnection.connectWith($"127.0.0.1:{port}", ccfg)

  # openStream runs into STREAM_ID_BLOCKED immediately. The retry window
  # in QUIC_CMD_OPEN_BIDI is ~2s — bound the call in a bg thread so a
  # hang fails with a clean assertion.
  resetBg()
  var h: int = & pendingOpenStreamBg(client)
  assert(waitForBg(45000l),
    "openStream with 0 budget did not return within 45s")
  assert(bgResultInt == 0,
    "openStream with 0 budget should return a closed stream")
  h ~

  # Connection itself must still be usable for close etc.
  client.close()
  server.close()
  print("PASS\n")

# ==============================================================================
# Test 54: a non-default stream window config must not break a basic round trip.
# ==============================================================================
# Regression gate for setMaxStreamWindow working end-to-end with a value
# smaller than the 256 KB default. The payload here is deliberately
# sized to fit comfortably within the configured window, so this test
# verifies the config propagation + initial transport param wiring
# without depending on MAX_STREAM_DATA delivery timing (which is
# inherently scheduler-dependent on the loopback). A more aggressive
# window-update stress test would need a dedicated harness driving the
# server I/O thread, which is out of scope here.

fn main(): void =>
  print("=== SDK QUIC Resilience Tests ===\n\n")

  test_write_after_close_is_safe()
  test_openstream_after_abrupt_drop_is_safe()
  test_bind_missing_cert_file_fails_clean()
  test_bind_with_malformed_address_fails_clean()
  test_connect_to_tcp_listener_is_bounded()
  test_connect_with_malformed_address()
  test_migrate_on_closed_conn_is_safe()
  test_write_empty_bytes_is_safe()
  test_double_close_is_safe()
  test_config_zero_max_bidi_streams_blocks_opens()

  print("\nAll QUIC resilience tests passed!\n")
